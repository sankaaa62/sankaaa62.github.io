---
// Интерактивная карта опыта (/orbit/) — официальный раздел портфолио,
// встроенный на главную как виджет-миникарта (см. OrbitMapCard.astro) и со
// страниц проектов (кнопка "Показать на карте"). Технически изолирована от
// основного сайта: свой layout (не Base.astro), свой css (styles/orbit.css,
// не импортирует global.css), свои скрипты (scripts/orbit*.js) — единственная
// связь с основным сайтом на уровне разметки - обратная ссылка в HUD и
// deep-link #focus=<slug> с карточек проектов (внешние ссылки на сторы/
// соцсети — тоже можно). См. docs/superpowers/specs/2026-07-02-portfolio-
// site-design.md, раздел «Итерация 10».
//
// Концепция v2 (по заданию владельца): не скролл-рассказ, а ИНТЕРАКТИВНАЯ
// КАРТА звездной системы. Камера (pan/zoom + клик-фокус) вместо прокрутки.
// Звезда в центре — визитка (портрет, контакты), а не первое место работы.
// Орбиты раскручиваются от последней к первой: ближняя — "Сейчас", дальняя —
// исток (Black Games). Вся математика позиционирования — в мировых
// координатах сцены (0,0 = звезда), камера — CSS-transform translate+scale
// на #orbit-scene, детали в orbit.js.
//
// Данные вех/дат/компаний согласованы с основной версией сайта:
// - вехи (kicker/range/milestone-текст) — из src/components/About.astro
// - проекты — из content-коллекции projects (ru/*.md)
// - прототипы — из content-коллекции prototypes (prototypes.json)
// - навыки — из src/components/Skills.astro (плоский список категорий)
// - визитка (имя/роль/hero.about/контакты) — из src/i18n/ui.ts + SocialIcons.astro
import { getCollection, render } from 'astro:content';
import { existsSync, readdirSync } from 'node:fs';
import '@fontsource-variable/inter';
import '@fontsource-variable/jetbrains-mono';
import '../styles/orbit.css';
import { platformBadges } from '../lib/platforms';
import SocialIcons from '../components/SocialIcons.astro';

const allProjects = await getCollection('projects', (p) => p.id.startsWith('ru/'));
const bySlug = Object.fromEntries(allProjects.map((p) => [p.id.split('/')[1], p.data]));

function coverFor(slug: string): string {
  const cover = `public/media/projects/${slug}/cover.webp`;
  if (existsSync(cover)) return `/media/projects/${slug}/cover.webp`;
  return `/media/projects/${slug}/shot-1.webp`;
}

// --- итерация 10 (п.6e): карточка проекта на карте получает тот же
// Steam-стиль вьювер, что и страница проекта основной версии
// (ProjectPage.astro/MediaViewer.astro) — плейлист [локальные трейлеры,
// youtube, скрины], собранный fs-сканом на этапе SSG. Не импортируем
// MediaViewer.astro (он тянет i18n main-сайта и рендерит свою SSR-разметку) —
// здесь только данные, сама разметка вьювера строится на клиенте через
// buildViewer()/attachViewer() из media-viewer.js (тот же прием, что и у
// роя прототипов, см. orbit-prototypes.js). Скан трейлеров — по паттерну
// (не жесткий список ['trailer.webm','trailer-2.webm']), т.к. у
// forsaken-kingdom скоро появится до 4 роликов (trailer.webm..trailer-4.webm).
type ViewerPlaylistItem = { kind: 'video' | 'youtube' | 'image'; src: string; id: string; poster: string };
function buildProjectPlaylist(slug: string, youtube?: string): ViewerPlaylistItem[] {
  const mediaDir = `public/media/projects/${slug}`;
  const webPath = (name: string) => `/media/projects/${slug}/${name}`;
  const hasFile = (name: string) => existsSync(`${mediaDir}/${name}`);
  const localPoster = hasFile('cover.webp') ? webPath('cover.webp') : hasFile('shot-1.webp') ? webPath('shot-1.webp') : '';
  const localVideos: ViewerPlaylistItem[] = existsSync(mediaDir)
    ? readdirSync(mediaDir)
        .filter((f) => /^trailer(-\d+)?\.webm$/.test(f))
        .sort((a, b) => a.localeCompare(b, undefined, { numeric: true }))
        .map((f) => ({ kind: 'video', src: webPath(f), id: '', poster: localPoster }))
    : [];
  const youtubeItems: ViewerPlaylistItem[] = youtube
    ? [{ kind: 'youtube', src: '', id: youtube, poster: `https://i.ytimg.com/vi/${youtube}/mqdefault.jpg` }]
    : [];
  const shots: ViewerPlaylistItem[] = existsSync(mediaDir)
    ? readdirSync(mediaDir)
        .filter((f) => /^shot-\d+\.webp$/.test(f))
        .sort((a, b) => a.localeCompare(b, undefined, { numeric: true }))
        .map((f) => ({ kind: 'image', src: webPath(f), id: '', poster: '' }))
    : [];
  return [...localVideos, ...youtubeItems, ...shots];
}

// краткое описание проекта (тело .md-файла) — рендерится тем же способом,
// что ProjectPage.astro (Astro 7: import { render } из astro:content, НЕ
// устаревший entry.render()). Считается один раз на все планеты.
const contentBySlug: Record<string, Awaited<ReturnType<typeof render>>['Content']> = {};
for (const p of allProjects) {
  const { Content } = await render(p);
  contentBySlug[p.id.split('/')[1]] = Content;
}

// --- переводит "мировой" угол (0 = север/верх, по часовой) + радиус в
// координаты сцены (px от звезды) — та же система, в которой работает
// орбитальный CSS-поворот (rotate(angleDeg) на элементе, заякоренном сверху) ---
function polar(radius: number, angleDeg: number): { x: number; y: number } {
  const rad = (angleDeg * Math.PI) / 180;
  return { x: Math.round(radius * Math.sin(rad)), y: Math.round(-radius * Math.cos(rad)) };
}

type PlanetSpec = { slug: string; size: number; angle: number };
type Era = {
  id: string;
  kicker: string;
  range: string;
  color: string;
  radius: number;
  duration: number;
  milestone: string;
  planets: PlanetSpec[];
};

function hashStr(s: string): number {
  let h = 0;
  for (let i = 0; i < s.length; i++) h = (h * 31 + s.charCodeAt(i)) | 0;
  return h;
}
function mulberry32(seed: number) {
  let a = seed;
  return function () {
    a |= 0; a = (a + 0x6d2b79f5) | 0;
    let t = Math.imul(a ^ (a >>> 15), 1 | a);
    t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };
}
// джиттер [1-spread, 1+spread], детерминированный от строки-семени (без
// Math.random — стабильность SSR и повторяемость между сборками)
function jitterFactor(seed: string, spread: number): number {
  const rand = mulberry32(hashStr(seed));
  return 1 + (rand() * 2 - 1) * spread;
}

// --- итерация 10 (п.1): стартовые углы планет разведены константами, чтобы
// планеты не накладывались друг на друга и не садились ровно под подпись
// орбиты (та на angle=0/север, см. .orbit-label ниже). ERA_ANGLE_STEP —
// шаг фазы между соседними орбитами, в пределах 70-110 градусов по фидбеку;
// PLANET_PAIR_OFFSET — противофаза для двух планет одной орбиты (Days After
// и Forsaken Kingdom на орбите "Сейчас"). ---
const ERA_ANGLE_OFFSET = 50; // сдвиг от подписи орбиты
const ERA_ANGLE_STEP = 90; // шаг между соседними орбитами (70-110 по ТЗ)
const PLANET_PAIR_OFFSET = 180; // противофаза двух планет на одной орбите
// итерация 10 (п.3): скорость планет замедлена вдвое относительно v2 —
// движение читалось слишком суетливым. Джиттер +-15% на планету (по slug),
// чтобы соседи не двигались синхронно даже с одинаковой базовой скоростью.
const PLANET_DURATION_JITTER = 0.15;

// Радиусы растут от "Сейчас" к истоку — раскрутка орбит от последней к первой
// (п.3 задания). Периоды обращения — как у настоящих планет: ближе к звезде
// = быстрее (Меркурий облетает Солнце быстрее Земли), но сильно замедлено
// (десятки-сотни секунд), чтобы движение читалось как медленный фон, а не
// отвлекало.
const eraDefs: Era[] = [
  {
    id: 'now',
    kicker: 'Сейчас',
    range: '2026 — н.в.',
    color: 'var(--accent)',
    radius: 300,
    duration: 124,
    milestone:
      'Лайвопс Days After в Reaction Games (10M+ установок) и парт-тайм — единственный программист roguelite-автобатлера Forsaken Kingdom для Steam.',
    planets: [
      { slug: 'days-after', size: 168, angle: 0 },
      { slug: 'forsaken-kingdom', size: 122, angle: 0 },
    ],
  },
  {
    id: 'taptap',
    kicker: 'Taptap Studio',
    range: '2026',
    color: 'var(--violet)',
    radius: 480,
    duration: 184,
    milestone:
      'На lead-позиции стабилизировал мобильный idle-тайкун и вывел его из техдолга, выстроил инженерную культуру и перевел команду на агентскую разработку (Claude Code, Codex) со строгим ревью — фичи стали выходить примерно в 2 раза быстрее.',
    planets: [{ slug: 'mafia-stories', size: 140, angle: 0 }],
  },
  {
    id: 'reaction',
    kicker: 'Reaction Games',
    range: '2023 — 2026',
    color: 'var(--teal)',
    radius: 660,
    duration: 256,
    milestone:
      'Один из разработчиков Dead Impact — кооперативной action-RPG на ECS/DOTS с кодовой базой 800K+ строк. Провел проект от tech launch до глобального релиза с 500K+ установок.',
    planets: [{ slug: 'dead-impact', size: 156, angle: 0 }],
  },
  {
    id: 'blackgames',
    kicker: 'Black Games',
    range: '2020 — 2023',
    color: 'var(--gold)',
    radius: 860,
    duration: 352,
    milestone:
      'Пришел первым разработчиком в стартап. За три года собрал отдел разработки с нуля, руководил командой до 8 программистов, выстроил процессы и выпустил 200+ прототипов, а также релизы с миллионами установок. Позже вел техническую часть «Last Wish»: релиз в Steam и VK Play, финалист акселератора «Start Game».',
    planets: [{ slug: 'last-wish', size: 142, angle: 0 }],
  },
];
// углы проставляются программно по формуле ERA_ANGLE_OFFSET + eraIndex*ERA_ANGLE_STEP
// (вторая планета орбиты — та же фаза + PLANET_PAIR_OFFSET), а не захардкожены
// по одному — так значения гарантированно следуют константам выше
const eras: Era[] = eraDefs.map((era, eraIndex) => {
  const base = ERA_ANGLE_OFFSET + eraIndex * ERA_ANGLE_STEP;
  return {
    ...era,
    planets: era.planets.map((p, i) => ({ ...p, angle: base + i * PLANET_PAIR_OFFSET })),
  };
});
const maxOrbitRadius = Math.max(...eras.map((e) => e.radius));

// --- пояс навыков: астероидный пояс между орбитами Reaction и Black Games ---
// (между 3-й и 4-й орбитой — как настоящий пояс астероидов между Марсом и
// Юпитером). Список навыков — из Skills.astro, без деления на marquee-ряды:
// здесь это статичное кольцо, а не бегущая лента.
const skillCategories = [
  { skills: ['Unity', 'C#', 'ECS/DOTS', 'Jobs/Burst'], core: true },
  { skills: ['Client-Server', 'Multiplayer', 'Event Sourcing', 'Clean Architecture', 'SOLID', 'DI', 'Unit Testing', 'Data Migrations', 'Meta/F2P systems'], core: false },
  { skills: ['Profiling', 'Mobile Optimization', 'Addressables', 'AssetBundles', 'URP'], core: false },
  { skills: ['Team Leadership', 'Hiring & Interviews', 'Mentoring', 'Code Review', 'Sprint Planning', 'Agile', 'Git', 'CI/CD', 'Live-ops', 'Prototyping', 'Analytics'], core: false },
  { skills: ['AI-assisted development', 'Claude Code', 'Codex', 'AI pipeline'], core: false },
];
const coreSkills = new Set(skillCategories.find((c) => c.core)!.skills);
const flatSkills = skillCategories.flatMap((c) => c.skills);

const BELT_R_MIN = 720;
const BELT_R_MAX = 800;
const beltChips = flatSkills.map((label) => {
  const rand = mulberry32(hashStr(`belt-${label}`));
  const radius = BELT_R_MIN + rand() * (BELT_R_MAX - BELT_R_MIN);
  const angle = rand() * 360;
  const duration = 90 + rand() * 130;
  const dir = rand() < 0.5 ? 'cw' : 'ccw';
  // угол на кольце задается ИСКЛЮЧИТЕЛЬНО через отрицательный delay
  // (фаза старта анимации ротора) — та же техника, что и у планет. Статичный
  // rotate() на анкоре тут не годится: translate(-50%,-50%) в том же
  // transform-списке считается ДО rotate и не поворачивается вместе с ним
  // (проверено), так что rotate() только наклонил бы саму плашку на угол,
  // а не переместил ее по кругу.
  const delay = -(angle / 360) * duration;
  return { label, radius, angle, duration, dir, delay: delay.toFixed(2), core: coreSkills.has(label) };
});

// --- рой прототипов: за орбитой Black Games (истока), детерминированные
// псевдослучайные позиции по id — раскладка стабильна между сборками. ---
const SWARM_R_MIN = 940;
const SWARM_R_MAX = 1300;
// итерация 10 (п.3): дрейф астероидов был еле заметен (7s, амплитуда 6px) —
// ускорено в ~2.9 раза (в пределах требуемых 2-4х), джиттер шире, чем у
// планет (0.45 против 0.15), т.к. рой должен выглядеть более хаотично
const ASTEROID_DRIFT_BASE = 2.4;
const ASTEROID_DRIFT_JITTER = 0.45;
const prototypes = (await getCollection('prototypes')).sort((a, b) => a.data.year - b.data.year || a.data.id.localeCompare(b.data.id));
const asteroids = prototypes.map((p) => {
  const rand = mulberry32(hashStr(p.data.id));
  const radius = SWARM_R_MIN + rand() * (SWARM_R_MAX - SWARM_R_MIN);
  const angle = rand() * 360;
  const pos = polar(radius, angle);
  return {
    id: p.data.id,
    title: p.data.title,
    genre: p.data.genre.ru,
    year: p.data.year,
    clip: p.data.clip,
    clipFull: p.data.clipFull,
    shots: p.data.shots,
    extraClips: p.data.extraClips ?? 0,
    link: p.data.link,
    badge: p.data.badge?.ru,
    x: pos.x,
    y: pos.y,
    size: Math.round(38 + rand() * 30),
    delay: (rand() * 6).toFixed(2),
    driftDuration: (ASTEROID_DRIFT_BASE * jitterFactor(`drift-${p.data.id}`, ASTEROID_DRIFT_JITTER)).toFixed(2),
  };
});
const fillerDots = Array.from({ length: 70 }, (_, i) => {
  const rand = mulberry32(hashStr(`filler-${i}`));
  const radius = SWARM_R_MIN * 0.6 + rand() * (SWARM_R_MAX * 1.05 - SWARM_R_MIN * 0.6);
  const angle = rand() * 360;
  const pos = polar(radius, angle);
  return { x: pos.x, y: pos.y, size: (2 + rand() * 4).toFixed(1) };
});

const heroAbout =
  'Уже больше шести лет с удовольствием делаю игры: от многомиллионных F2P-хитов до ламповых инди, от MMO до гиперказуалок, под мобильные и ПК, в больших командах и соло. Выстраивал процессы и собирал команду, менторил новичков, налаживал AI-пайплайн, оптимизировал сетевой код и строил конвейер прототипов.';

// данные для orbit.js (камера/фокус/HUD) — без дублирования на клиенте того,
// что уже посчитано здесь на сервере
const orbitData = {
  maxOrbitRadius,
  eras: eras.map((e) => ({ id: e.id, kicker: e.kicker, range: e.range, radius: e.radius, milestone: e.milestone })),
};

const title = 'Интерактивная карта опыта — Александр Кандаков';
const description = 'Интерактивная карта опыта: карьера Александра Кандакова как карта звездной системы. Орбиты-вехи, планеты-проекты, звезда-визитка.';
---
<!doctype html>
<html lang="ru">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
</head>
<body class="orbit-body">
  <!-- фон: аврора + звездное поле (canvas, адаптирован под camera-parallax, см. orbit-stars.js) -->
  <div class="orbit-depth-fade" aria-hidden="true"></div>
  <div id="orbit-bg-a" aria-hidden="true"><div class="bg-inner"></div></div>
  <div id="orbit-bg-b" aria-hidden="true"><div class="bg-inner"></div></div>
  <canvas id="orbit-stars-canvas" aria-hidden="true"></canvas>

  <!-- камера: viewport (слушает pan/zoom-жесты) содержит сцену (transform) -->
  <div id="orbit-viewport" class="orbit-viewport">
    <div id="orbit-scene" class="orbit-scene">
      <!-- орбитальные кольца (SVG — pointer-events:stroke дает клик именно по
           линии кольца, не по всей внутренней площади круга) -->
      <svg class="orbit-rings" viewBox="-1000 -1000 2000 2000" aria-hidden="true">
        {eras.map((era) => (
          <g class="ring-group" data-focus-era={era.id}>
            <circle class="ring-hit" cx="0" cy="0" r={era.radius} />
            <circle class="ring-line" cx="0" cy="0" r={era.radius} style={`--era-color:${era.color}`} />
          </g>
        ))}
      </svg>

      <!-- подписи орбит: статичные точки на севере каждого кольца (не
           вращаются вместе с планетами) — приглушены, пока орбита не в фокусе -->
      {eras.map((era) => (
        <div class="orbit-label" style={`left:0px;top:${-era.radius}px`} data-era-label={era.id}>
          <div class="orbit-counter-zoom">
            <p class="mono era-label-kicker" style={`--era-color:${era.color}`}>{era.kicker}</p>
            <p class="mono era-label-range">{era.range}</p>
          </div>
        </div>
      ))}

      <!-- звезда-визитка: якорь мировой системы координат (0,0). Постоянная
           подпись — только имя (п.5); роль ушла в hover-блок (п.6, данные —
           в data-атрибутах, читает orbit.js). Диск-заглушка за фоткой убран
           (п.4) — .star-halo теперь чистое box-shadow свечение без заливки,
           см. orbit.css. -->
      <div class="star-anchor" style="left:0px;top:0px">
        <div class="orbit-counter-zoom">
          <button
            type="button"
            class="orbit-star reset"
            data-star-open
            data-hover-role="Senior Unity Developer"
            data-hover-years="6+ лет в геймдеве"
            data-hover-cta="Нажмите, чтобы открыть визитку"
            aria-label="Визитка Александра Кандакова — открыть"
          >
            <span class="star-halo" aria-hidden="true"></span>
            <img src="/media/me.webp" alt="" loading="eager" />
          </button>
          <div class="star-label">
            <p class="star-name">Александр Кандаков</p>
          </div>
        </div>
      </div>

      <!-- планеты-проекты -->
      {eras.map((era) => (
        <>
          {era.planets.map((planet) => {
            const d = bySlug[planet.slug];
            // итерация 10 (п.3): у каждой планеты своя скорость — джиттер
            // +-15% от базовой длительности орбиты, детерминированный по slug
            const planetDuration = era.duration * jitterFactor(planet.slug, PLANET_DURATION_JITTER);
            const delay = (-(planet.angle / 360) * planetDuration).toFixed(2);
            return (
              <div
                class="orbit-rotor"
                data-era={era.id}
                style={`--r:${era.radius}px;--dur:${planetDuration.toFixed(2)}s;--delay:${delay}s`}
              >
                <div class="orbit-anchor">
                  <div class="orbit-counter-rotate">
                    <div class="orbit-counter-zoom planet-wrap">
                      <button
                        type="button"
                        class="planet reset"
                        data-planet-open
                        data-era={era.id}
                        data-tpl={`tpl-${planet.slug}`}
                        data-hover-role={d.role}
                        data-hover-period={d.period}
                        data-hover-metric={d.metrics[0]}
                        style={`--size:${planet.size}px;--era-color:${era.color}`}
                        aria-label={`${d.title} — открыть карточку проекта`}
                      >
                        <img src={coverFor(planet.slug)} alt="" loading="lazy" />
                      </button>
                      <!-- п.5: только название — роль/период/метрика теперь в hover-блоке -->
                      <div class="planet-label">
                        <p class="planet-title">{d.title}</p>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            );
          })}
          {/* шаблон карточки — клонируется в общую модалку по клику планеты,
               см. orbit.js. .pcard-viewer пуст в SSR-разметке (только
               data-playlist/data-title) — сам Steam-стиль вьювер собирает
               orbit.js на клиенте через buildViewer()/attachViewer(), тем же
               приемом, что и модалка прототипов (orbit-prototypes.js) */}
          {era.planets.map((planet) => {
            const d = bySlug[planet.slug];
            const badges = platformBadges(d.platforms, { pc: 'PC', mobile: 'Mobile' });
            const playlist = buildProjectPlaylist(planet.slug, d.youtube);
            const DescriptionCmp = contentBySlug[planet.slug];
            return (
              <template id={`tpl-${planet.slug}`}>
                <div class="pcard">
                  <div class="pcard-viewer" data-playlist={JSON.stringify(playlist)} data-title={d.title} data-cover={coverFor(planet.slug)}></div>
                  <div class="pcard-body">
                    <div class="pcard-head">
                      <h3>{d.title}</h3>
                      <span class="pcard-role mono" style={`--era-color:${era.color}`}>{d.role}</span>
                    </div>
                    <p class="pcard-meta mono">{d.company} · {d.period} · {d.genre}</p>
                    <p class="pcard-tagline">{d.tagline}</p>
                    <div class="chip-row">
                      {d.metrics.map((m: string) => <span class="chip chip-ok">{m}</span>)}
                      {badges.map((b) => (
                        <span class="chip" set:html={b.svg + `<span>${b.label}</span>`} />
                      ))}
                    </div>
                    <div class="pcard-description">
                      <DescriptionCmp />
                    </div>
                    <div class="link-row">
                      {d.links.map((l: { label: string; url: string }) => (
                        <a class="pill-link" href={l.url} target="_blank" rel="noopener" style={`--era-color:${era.color}`}>{l.label} →</a>
                      ))}
                      <a class="pill-link pill-link--ghost" href={`/ru/projects/${planet.slug}/`} style={`--era-color:${era.color}`}>Страница проекта →</a>
                    </div>
                  </div>
                </div>
              </template>
            );
          })}
        </>
      ))}

      <!-- пояс навыков (астероидный пояс между Reaction и Black Games) -->
      {beltChips.map((chip) => (
        <div
          class="orbit-rotor belt-rotor"
          data-dir={chip.dir}
          style={`--r:${chip.radius}px;--dur:${chip.duration}s;--delay:${chip.delay}s`}
        >
          <div class="orbit-anchor">
            <div class="orbit-counter-rotate">
              <div class="orbit-counter-zoom">
                <span class={`chip belt-chip${chip.core ? ' chip-ok' : ''}`}>{chip.label}</span>
              </div>
            </div>
          </div>
        </div>
      ))}

      <!-- рой прототипов: фоновая пыль (декор, без взаимодействия) -->
      {fillerDots.map((f) => (
        <span class="filler-dot" style={`left:${f.x}px;top:${f.y}px;width:${f.size}px;height:${f.size}px`}></span>
      ))}
      <!-- рой прототипов: кликабельные астероиды -->
      {asteroids.map((a) => (
        <div class="debris-anchor" style={`left:${a.x}px;top:${a.y}px`}>
          <div class="orbit-counter-zoom">
            <button
              type="button"
              class="asteroid reset"
              style={`--size:${a.size}px;--delay:${a.delay}s;--drift-dur:${a.driftDuration}s`}
              data-id={a.id}
              data-title={a.title}
              data-genre={a.genre}
              data-year={a.year}
              data-clip={a.clip ? '1' : '0'}
              data-clip-full={a.clipFull ? '1' : '0'}
              data-shots={a.shots}
              data-extra-clips={a.extraClips}
              data-link={a.link ?? ''}
              data-badge={a.badge ?? ''}
              aria-label={`${a.title} — открыть`}
            >
              <img src={`/media/prototypes/${a.id}/icon.webp`} alt="" loading="lazy" draggable="false" />
              {a.badge && <span class="asteroid-badge mono">{a.badge}</span>}
            </button>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- HUD: заголовок/легенда/зум — фиксированные слои поверх камеры -->
  <div class="hud" aria-hidden="false">
    <div class="hud-panel hud-panel--top">
      <!-- итерация 10 (задача ZB, п.1): обратная ссылка на основной сайт -
           карта теперь официальный раздел портфолио. /ru/, т.к. сама
           карта на русском -->
      <a href="/ru/" class="hud-backlink mono">
        <span class="hud-backlink-arrow" aria-hidden="true">&larr;</span>
        На основной сайт
      </a>
      <p class="hud-kicker mono">Интерактивная карта опыта</p>
      <h1 class="hud-title">Орбиты</h1>
      <p class="hud-subtitle">Профессиональный путь как карта звездной системы. Перетаскивайте сцену, приближайте, кликайте по объектам.</p>
      <nav class="hud-legend" aria-label="Навигация по системе">
        <!-- итерация 10 (п.6c): пункт-обзор — активен по умолчанию, снимает
             фокус-режим (приглушение остальных орбит) и возвращает камеру
             ко всей системе целиком -->
        <button type="button" class="legend-item legend-overview" data-focus-overview>
          <span class="legend-dot legend-dot--overview" aria-hidden="true"></span>
          <span class="legend-label">Вся система</span>
        </button>
        <button type="button" class="legend-item legend-star" data-focus-star>
          <span class="legend-dot legend-dot--star" aria-hidden="true"></span>
          <span class="legend-label">Визитка</span>
        </button>
        {eras.map((era) => (
          <button type="button" class="legend-item" data-focus-era={era.id} style={`--era-color:${era.color}`}>
            <span class="legend-dot" aria-hidden="true"></span>
            <span class="legend-label">{era.kicker}</span>
            <span class="legend-range mono">{era.range}</span>
          </button>
        ))}
      </nav>
      <div class="hud-era-detail" data-era-detail aria-live="polite"></div>
    </div>

    <div class="hud-zoom">
      <button type="button" class="hud-zoom-btn" data-zoom="in" aria-label="Приблизить">+</button>
      <button type="button" class="hud-zoom-btn" data-zoom="out" aria-label="Отдалить">−</button>
      <button type="button" class="hud-zoom-btn hud-zoom-btn--fit" data-zoom="fit" aria-label="Показать всю систему">⤢</button>
    </div>

    <p class="hud-footer mono">© 2026 Aleksandr Kandakov</p>

    <div class="hud-hint" id="orbit-hint">
      <span>Перетащите сцену или нажмите на объект карты</span>
    </div>
  </div>

  <!-- итерация 10 (п.6): один общий hover-блок на всю страницу, а не по
       одному на планету/звезду — orbit.js наполняет и двигает его на
       pointerenter (только на устройствах с honest hover, см. гейт в JS).
       Вне #orbit-scene: позиция считается в экранных координатах, камера
       его не панорамирует/не зумит. -->
  <div class="hover-card" id="orbit-hover-card" aria-hidden="true"></div>

  <!-- модалка визитки -->
  <dialog id="orbit-star-modal" class="orbit-modal orbit-modal--star">
    <button type="button" class="modal-close" data-modal-close aria-label="Закрыть">✕</button>
    <div class="star-modal-body">
      <img src="/media/me.webp" alt="Александр Кандаков" class="star-modal-portrait" width="160" height="160" />
      <h2>Александр Кандаков</h2>
      <p class="mono star-modal-role">Senior Unity Developer</p>
      <p class="star-modal-about">{heroAbout}</p>
      <div class="star-modal-actions">
        <a class="star-cv-btn sheen" href="/cv/Kandakov_CV_ru.pdf" download>Скачать CV</a>
        <SocialIcons />
      </div>
    </div>
  </dialog>

  <!-- модалка карточки проекта (наполняется из <template> кликнутой планеты) -->
  <dialog id="orbit-project-modal" class="orbit-modal orbit-modal--project">
    <button type="button" class="modal-close" data-modal-close aria-label="Закрыть">✕</button>
    <div class="modal-slot" data-project-slot></div>
  </dialog>

  <!-- модалка прототипа (вьювер собирается на клиенте через media-viewer.js) -->
  <dialog id="orbit-proto-modal" class="orbit-modal orbit-modal--proto">
    <button type="button" class="modal-close" data-modal-close aria-label="Закрыть">✕</button>
    <div class="opm-body">
      <div class="opm-head">
        <h3 class="opm-title"></h3>
        <span class="opm-badge mono" style="display:none;"></span>
      </div>
      <p class="opm-meta mono"></p>
      <a class="opm-link pill-link" target="_blank" rel="noopener" style="display:none;"></a>
      <div class="opm-viewer"></div>
    </div>
  </dialog>

  <script define:vars={{ orbitData }} is:inline>
    window.__ORBIT_DATA__ = orbitData;
  </script>
  <script src="../scripts/orbit-stars.js"></script>
  <script src="../scripts/orbit.js"></script>
  <script src="../scripts/orbit-prototypes.js"></script>
</body>
</html>
