---
import { t, type Locale } from '../i18n/ui';
const { locale } = Astro.props as { locale: Locale };

// Задача RR (iter8): «Астероидный пояс» — финальная форма секции Skills.
// Раньше (iter7, Задача OO) было три переключаемых SSR-варианта (A
// «Категории», B «Созвездия», C «Бегущие ряды») с mono-свитчером и
// localStorage (отдельный JS-скрипт переключателя). Пользователь выбрал
// вариант C — свитчер, разметка и стили A/B удалены целиком вместе со скриптом.
// Вариант A не пропал бесследно: его данные теперь идут в плоский
// .sr-only список ниже — семантический fallback для скринридеров/SEO
// (сама лента — CSS-анимация марафона, видна и без JS, но набор навыков
// как обычный текст в DOM все равно важен для доступности).
interface SkillCategory {
  id: string;
  label: { en: string; ru: string };
  skills: string[];
}

const categories: SkillCategory[] = [
  {
    id: 'core',
    label: { en: 'Core', ru: 'Ядро' },
    skills: ['Unity', 'C#', 'ECS/DOTS', 'Jobs/Burst'],
  },
  {
    id: 'multiplayer',
    label: { en: 'Multiplayer & Architecture', ru: 'Мультиплеер и архитектура' },
    skills: ['Client-Server', 'Multiplayer', 'Event Sourcing', 'Clean Architecture', 'SOLID', 'DI', 'Unit Testing', 'Data Migrations', 'Meta/F2P systems'],
  },
  {
    id: 'performance',
    label: { en: 'Performance', ru: 'Производительность' },
    skills: ['Profiling', 'Mobile Optimization', 'Addressables', 'AssetBundles', 'URP'],
  },
  {
    id: 'leadership',
    label: { en: 'Leadership & Process', ru: 'Лидерство и процессы' },
    skills: ['Team Leadership', 'Hiring & Interviews', 'Mentoring', 'Code Review', 'Sprint Planning', 'Agile', 'Git', 'CI/CD', 'Live-ops', 'Prototyping', 'Analytics'],
  },
  {
    id: 'ai',
    label: { en: 'AI', ru: 'AI' },
    skills: ['AI-assisted development', 'Claude Code', 'Codex', 'AI pipeline'],
  },
];

// RR.5: ядро стека — отдельный цветовой акцент в ленте (см. .skill-core ниже).
const CORE_SKILLS = new Set(categories.find((c) => c.id === 'core')!.skills);

// Детерминированное "перемешивание" без RNG (стабильно между сборками/SSR):
// раздаем навыки по кругу — по одному из каждой категории за проход — так
// соседние элементы почти никогда не из одной категории.
function interleave(cats: SkillCategory[]): string[] {
  const maxLen = Math.max(...cats.map((c) => c.skills.length));
  const out: string[] = [];
  for (let i = 0; i < maxLen; i++) {
    for (const c of cats) if (c.skills[i]) out.push(c.skills[i]);
  }
  return out;
}
const mixed = interleave(categories);
const marqueeRows: string[][] = [[], [], []];
mixed.forEach((s, i) => marqueeRows[i % 3].push(s));

// iter9 п.6, фикс зацикливания: трек = 2 группы .marquee-group, анимация
// -50% (ширина одной группы). Если группа уже вьюпорта, к концу цикла справа
// появляется пустота и контент "прыгает" на reset. Гарантируем ширину группы
// >= самых широких экранов (4К/ультравайд), повторяя контент ряда внутри
// группы: оценка ширины та же, что в estimateDuration, с запасом на
// неточность шрифтовой оценки.
const MIN_GROUP_PX = 4200;
function rowPx(row: string[]): number {
  return row.reduce((sum, s) => sum + s.length * 7.4 + 34, 0);
}
const repeatedRows = marqueeRows.map((row) => {
  const repeats = Math.max(1, Math.ceil(MIN_GROUP_PX / rowPx(row)));
  const out: string[] = [];
  for (let r = 0; r < repeats; r++) out.push(...row);
  return out;
});

// RR.4: у каждого ряда своя скорость и свой промежуток между чипами —
// усиливает ощущение "разных орбит пояса", а не трех одинаковых лент.
// Направление чередуется через marquee-row--rev (см. стили) — соседние
// ряды всегда бегут навстречу друг другу.
const ROW_SPEED = [28, 36, 24]; // px/s
const ROW_GAP = [10, 14, 8]; // px

// ~ROW_SPEED px/s: длительность оценивается по контенту ГРУППЫ (в % от
// ширины трека — см. keyframes ниже), реальные px не считаем, но целимся
// в похожую скорость для каждого ряда отдельно.
function estimateDuration(row: string[], speedPxS: number): number {
  return Math.max(14, Math.round(rowPx(row) / speedPxS));
}

// Плоский список всех навыков в порядке категорий — .sr-only fallback.
const allSkillsFlat = categories.flatMap((c) => c.skills);
---
<section id="skills" class="skills-band" aria-label={t(locale, 'skills.title')}>
  <div class="marquee-wrap">
    <div class="marquee-fade marquee-fade--left" aria-hidden="true"></div>
    {repeatedRows.map((row, ri) => (
      <div class={`marquee-row${ri % 2 === 1 ? ' marquee-row--rev' : ''}`}>
        <div class="marquee-track" style={`--duration:${estimateDuration(row, ROW_SPEED[ri])}s;--gap:${ROW_GAP[ri]}px`}>
          <div class="marquee-group">
            {row.map((s, si) => <span class={`tag size-${si % 3}${CORE_SKILLS.has(s) ? ' skill-core' : ''}`} data-off={si % 2}>{s}</span>)}
          </div>
          <div class="marquee-group" aria-hidden="true">
            {row.map((s, si) => <span class={`tag size-${si % 3}${CORE_SKILLS.has(s) ? ' skill-core' : ''}`} data-off={si % 2}>{s}</span>)}
          </div>
        </div>
      </div>
    ))}
    <div class="marquee-fade marquee-fade--right" aria-hidden="true"></div>
  </div>

  <!-- Семантический fallback (скринридеры/SEO) — см. комментарий вверху файла. -->
  <ul class="sr-only">
    {allSkillsFlat.map((s) => <li>{s}</li>)}
  </ul>
</section>

<style>
  /* RR.6: full-bleed лента-разделитель между "Обо мне" и "Проектами" —
     вырывается из .container до ширины viewport стандартным приемом с
     отрицательными margin; overflow-x:hidden на body (global.css) не дает
     появиться горизонтальному скроллу от этого приема (уже используется
     тем же способом в carousel — PrototypeGrid.astro). */
  .skills-band {
    width: 100vw;
    position: relative;
    left: 50%;
    right: 50%;
    margin-left: -50vw;
    margin-right: -50vw;
    padding-block: 48px;
    overflow: hidden;
  }

  .marquee-wrap { position: relative; display: flex; flex-direction: column; gap: 14px; }
  .marquee-row { overflow: hidden; padding-block: 10px; }
  .marquee-track { display: flex; width: max-content; animation: marquee-left var(--duration, 40s) linear infinite; }
  .marquee-row--rev .marquee-track { animation-name: marquee-right; }
  .marquee-row:hover .marquee-track { animation-play-state: paused; }
  .marquee-group {
    display: flex;
    flex: 0 0 auto;
    align-items: center;
    gap: var(--gap, 10px);
    padding-right: var(--gap, 10px);
  }
  @keyframes marquee-left {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
  @keyframes marquee-right {
    from { transform: translateX(-50%); }
    to { transform: translateX(0); }
  }

  /* RR.4/iter9 п.6: астероиды разных калибров — 3 размера чипа по позиции
     в ПОВТОРЕННОМ ряду, детерминированно (индекс элемента, без RNG и без
     nth-child). nth-child ломался на швах: длина ряда не кратна 3 —
     на стыке двух групп и между повторами внутри группы паттерн размеров
     "мигал". Классы size-N/data-off считаются от индекса в разметке —
     обе группы построены идентично, поэтому стык групп всегда бесшовный.
     Легкие вертикальные офсеты вперемешку — рой, а не ровная строка. */
  .marquee-group .tag.size-0 { font-size: .72rem; }
  .marquee-group .tag.size-1 { font-size: .82rem; }
  .marquee-group .tag.size-2 { font-size: .94rem; }
  .marquee-group .tag[data-off="0"] { transform: translateY(-4px); }
  .marquee-group .tag[data-off="1"] { transform: translateY(4px); }

  /* RR.5: ядро стека — акцент цветом, читаемо на темном фоне поверхности. */
  .tag.skill-core {
    color: var(--accent);
    border-color: var(--accent);
  }

  /* RR.5: края ленты — шире и мягче, многоступенчатый градиент вместо
     жесткого двухцветного (ср. .proto-fade в PrototypeGrid.astro). Цвет
     дублирует var(--bg) буквально как rgb(14,15,19) — linear-gradient не
     умеет смешать var() с прозрачностью без color-mix(); тот же прием c
     буквальными rgba под accent-цвета уже применялся в этом компоненте. */
  .marquee-fade {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 110px;
    pointer-events: none;
    z-index: 1;
  }
  .marquee-fade--left {
    left: 0;
    background: linear-gradient(to right,
      rgb(14, 15, 19) 0%,
      rgba(14, 15, 19, .94) 20%,
      rgba(14, 15, 19, .75) 40%,
      rgba(14, 15, 19, .45) 62%,
      rgba(14, 15, 19, .18) 82%,
      transparent 100%);
  }
  .marquee-fade--right {
    right: 0;
    background: linear-gradient(to left,
      rgb(14, 15, 19) 0%,
      rgba(14, 15, 19, .94) 20%,
      rgba(14, 15, 19, .75) 40%,
      rgba(14, 15, 19, .45) 62%,
      rgba(14, 15, 19, .18) 82%,
      transparent 100%);
  }

  @media (max-width: 480px) {
    .marquee-fade { width: 56px; }
  }
</style>
