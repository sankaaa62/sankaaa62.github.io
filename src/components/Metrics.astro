---
import { t, type Locale } from '../i18n/ui';
const { locale } = Astro.props as { locale: Locale };
const items = [
  { value: 6, suffix: '+', label: t(locale, 'metrics.years') },
  { value: 10, suffix: 'M+', label: t(locale, 'metrics.installs') },
  { value: 200, suffix: '+', label: t(locale, 'metrics.protos') },
  { value: 8, suffix: '', prefix: '0→', label: t(locale, 'metrics.team') },
];
---
<div class="metrics">
  <div class="metrics-grid">
    {items.map((m, i) => (
      <div class="metric reveal" style={`--i:${i}`}>
        <div class="metric-value mono">
          {m.prefix ?? ''}<span class="counter" data-target={m.value}>0</span>{m.suffix}
        </div>
        <div class="metric-label">{m.label}</div>
      </div>
    ))}
  </div>
</div>

<style>
  /* iter7 (п.5): редизайн — убраны SVG-созвездия и угловые звездочки-спарки,
     остаются числа (с прежним glow) + подписи. Разделители между колонками —
     тонкие вертикальные border-left (только на десктопной 4-колоночной сетке;
     на мобильной 2×2 разделителей нет — см. media-запрос ниже).
     iter8 (п.7): убран градиентный underline под числом (.metric-value::after) —
     остаются только цифры с glow, подписи и вертикальные разделители. */
  .metrics {
    margin-bottom: clamp(28px, 5vw, 44px);
  }

  .metrics-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 14px;
  }

  .metric {
    padding: 16px 10px;
    text-align: center;
  }

  .metric + .metric {
    border-left: 1px solid var(--border);
  }

  .metric-value {
    position: relative;
    display: inline-block;
    font-size: clamp(1.6rem, 4vw, 2.1rem);
    font-weight: 800;
    color: var(--accent-2);
    text-shadow: 0 0 12px rgba(255, 176, 26, .55), 0 0 26px rgba(255, 92, 26, .25);
  }

  .metric-label {
    margin-top: 4px;
    color: var(--muted);
    font-size: .85rem;
  }

  @media (max-width: 640px) {
    .metrics-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 22px 14px;
    }

    .metric + .metric {
      border-left: none;
    }
  }
</style>
