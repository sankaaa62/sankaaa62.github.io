---
import { t, type Locale } from '../i18n/ui';
import SocialIcons from './SocialIcons.astro';
const { locale } = Astro.props as { locale: Locale };
---
<section id="contact" class="section container" style="text-align:center;padding-top:96px;padding-bottom:96px;">
  <div class="contact-card">
    <svg class="constellation" viewBox="0 0 640 360" preserveAspectRatio="xMidYMid slice" aria-hidden="true" focusable="false">
      <g stroke="var(--border)" stroke-width="1" opacity="0.6" fill="none">
        <line x1="40" y1="36" x2="90" y2="55" />
        <line x1="90" y1="55" x2="60" y2="95" />
        <line x1="60" y1="95" x2="40" y2="36" />
        <line x1="90" y1="55" x2="120" y2="40" />
        <line x1="560" y1="300" x2="600" y2="250" />
        <line x1="600" y1="250" x2="580" y2="320" />
        <line x1="560" y1="300" x2="520" y2="330" />
      </g>
      <g fill="var(--text)">
        <circle cx="40" cy="36" r="1.3" opacity="0.5" />
        <circle cx="90" cy="55" r="1.5" opacity="0.5">
          <animate attributeName="opacity" values="0.2;0.8;0.2" dur="4s" begin="0s" repeatCount="indefinite" />
        </circle>
        <circle cx="60" cy="95" r="1" opacity="0.4" />
        <circle cx="120" cy="40" r="1.2" opacity="0.45">
          <animate attributeName="opacity" values="0.2;0.8;0.2" dur="3.5s" begin="1.2s" repeatCount="indefinite" />
        </circle>
        <circle cx="560" cy="300" r="1.4" opacity="0.5" />
        <circle cx="600" cy="250" r="1" opacity="0.4">
          <animate attributeName="opacity" values="0.2;0.8;0.2" dur="5s" begin="2.4s" repeatCount="indefinite" />
        </circle>
        <circle cx="580" cy="320" r="1.2" opacity="0.45" />
        <circle cx="520" cy="330" r="1" opacity="0.4" />
      </g>
    </svg>
    <p class="mono" style="color:var(--accent);font-size:.9rem;margin:0 0 8px;">{t(locale, 'contact.kicker')}</p>
    <h2 class="reveal no-bar">{t(locale, 'contact.title')}</h2>
    <p style="color:var(--muted);max-width:52ch;margin:16px auto 0;">
      {t(locale, 'contact.copy')}
    </p>
    <div style="margin-top:32px;">
      <a class="btn-contact" href="mailto:kandakov.sasha@gmail.com">{t(locale, 'contact.cta')}</a>
    </div>
    <div style="display:flex;justify-content:center;margin-top:28px;">
      <SocialIcons />
    </div>
  </div>
</section>

<style>
  .contact-card {
    /* min() keeps a 20px safety gutter on narrow viewports even though the
       section's own horizontal padding is zeroed by a pre-existing cascade
       quirk (.section's shorthand padding, declared after .container in
       global.css, wins on left/right at equal specificity). */
    max-width: min(640px, calc(100% - 40px));
    margin: 0 auto;
    position: relative;
    isolation: isolate;
    overflow: hidden;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 48px 32px;
    box-shadow: 0 12px 48px rgba(255,92,26,.1);
  }
  /* iter6.GG: тонкая созвездная декорация — под текстом, не мешает читаемости */
  .constellation {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    pointer-events: none;
  }
  .btn-contact {
    display: inline-block;
    padding: 16px 34px;
    font-size: 1.05rem;
    border: 1px solid var(--accent);
    color: var(--accent);
    border-radius: var(--radius);
    transition: background .2s, transform .2s;
  }
  .btn-contact:hover {
    background: rgba(255,92,26,.08);
    transform: translateY(-2px);
    text-decoration: none;
  }
</style>
