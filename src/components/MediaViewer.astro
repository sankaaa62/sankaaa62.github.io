---
// Итерация 8, п.16: Steam-стиль медиа-вьювер на страницах проектов.
// Заменяет отдельный блок трейлера/youtube и секцию <Gallery> — один плейлист
// [видео (локальные трейлеры + youtube), затем все скрины], собранный на
// этапе SSG через fs (никакого ffmpeg в рантайме: постер локального видео —
// cover.webp/shot-1.webp, если есть).
import { readdirSync, existsSync } from 'node:fs';
import { t, type Locale } from '../i18n/ui';

interface Props {
  locale: Locale;
  slug: string;
  title: string;
  youtube?: string;
}

const { locale, slug, title, youtube } = Astro.props as Props;

const mediaDir = `public/media/projects/${slug}`;
const webPath = (name: string) => `/media/projects/${slug}/${name}`;
const hasFile = (name: string) => existsSync(`${mediaDir}/${name}`);

const localPoster = hasFile('cover.webp')
  ? webPath('cover.webp')
  : hasFile('shot-1.webp')
    ? webPath('shot-1.webp')
    : '';

interface PlaylistItem {
  kind: 'video' | 'youtube' | 'image';
  src: string;
  id: string;
  poster: string;
  label: string;
}

// iter10 (п.9): скан по паттерну (не жесткий список ['trailer.webm',
// 'trailer-2.webm']), т.к. у forsaken-kingdom теперь 4 ролика
// (trailer.webm..trailer-4.webm). Порядок не localeCompare(numeric) как у
// shots ниже: там имена всегда 'shot-N.webp', а у trailer.webm нет суффикса
// -N, из-за чего символ '-' (0x2D) лексикографически меньше '.' (0x2E) и
// localeCompare ставит trailer.webm ПОСЛЕ trailer-2..4 — обратный порядок.
// Извлекаем номер явно (trailer.webm = 1) и сортируем по нему числом.
const trailerOrder = (name: string) => {
  const match = name.match(/^trailer-(\d+)\.webm$/);
  return match ? Number(match[1]) : 1;
};
const localVideos: PlaylistItem[] = existsSync(mediaDir)
  ? readdirSync(mediaDir)
      .filter((f) => /^trailer(-\d+)?\.webm$/.test(f))
      .sort((a, b) => trailerOrder(a) - trailerOrder(b))
      .map((f) => ({ kind: 'video', src: webPath(f), id: '', poster: localPoster, label: '' }))
  : [];

const youtubeItems: PlaylistItem[] = youtube
  ? [{ kind: 'youtube', src: '', id: youtube, poster: `https://i.ytimg.com/vi/${youtube}/mqdefault.jpg`, label: '' }]
  : [];

const shots: PlaylistItem[] = existsSync(mediaDir)
  ? readdirSync(mediaDir)
      .filter((f) => /^shot-\d+\.webp$/.test(f))
      .sort((a, b) => a.localeCompare(b, undefined, { numeric: true }))
      .map((f) => ({ kind: 'image', src: webPath(f), id: '', poster: '', label: '' }))
  : [];

let videoCounter = 0;
let imageCounter = 0;
const playlist: PlaylistItem[] = [...localVideos, ...youtubeItems, ...shots].map((item) => {
  if (item.kind === 'image') {
    imageCounter += 1;
    return { ...item, label: `${t(locale, 'gallery.screenshot')} ${imageCounter}` };
  }
  videoCounter += 1;
  return { ...item, label: `${t(locale, 'viewer.video')} ${videoCounter}` };
});

const first = playlist[0];
---
{playlist.length > 0 && (
  <div class="media-viewer" data-title={title}>
    <div class="mv-stage" tabindex="0" aria-label={`${title} — media viewer`}>
      {first.kind === 'video' && (
        <video controls preload="metadata" poster={first.poster || undefined} playsinline>
          <source src={first.src} type="video/webm" />
        </video>
      )}
      {/* enablejsapi=1 нужен уже здесь (SSR), а не только у динамически
          создаваемых iframe в media-viewer.js: если этот youtube-слайд —
          первый в плейлисте, слайдшоу должно ловить его 'onStateChange'
          еще до первого клика по миниатюре */}
      {first.kind === 'youtube' && (
        <iframe
          src={`https://www.youtube-nocookie.com/embed/${first.id}?enablejsapi=1`}
          title={title}
          loading="lazy"
          referrerpolicy="strict-origin-when-cross-origin"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          allowfullscreen
        ></iframe>
      )}
      {first.kind === 'image' && (
        <img src={first.src} alt={title} decoding="async" />
      )}
    </div>

    <div class="mv-strip-wrap">
      <button type="button" class="mv-arrow mv-arrow--prev" aria-label={t(locale, 'carousel.prev')}>‹</button>
      <div class="mv-strip">
        {playlist.map((item, i) => (
          <button
            type="button"
            class={`mv-thumb${i === 0 ? ' is-active' : ''}`}
            data-index={i}
            data-kind={item.kind}
            data-src={item.src}
            data-id={item.id}
            data-poster={item.poster}
            aria-label={`${title} — ${item.label}`}
          >
            {item.kind === 'image' && <img src={item.src} loading="lazy" alt="" />}
            {item.kind === 'youtube' && <img src={item.poster} loading="lazy" alt="" />}
            {item.kind === 'video' && (item.poster
              ? <img src={item.poster} loading="lazy" alt="" />
              : <span class="mv-thumb-blank" aria-hidden="true"></span>)}
            {item.kind !== 'image' && <span class="mv-play" aria-hidden="true">▶</span>}
          </button>
        ))}
      </div>
      <button type="button" class="mv-arrow mv-arrow--next" aria-label={t(locale, 'carousel.next')}>›</button>
    </div>

    <dialog class="mv-lightbox">
      <button type="button" class="mv-lb-close" aria-label={t(locale, 'gallery.close')}>✕</button>
      <button type="button" class="mv-lb-prev" aria-label={t(locale, 'gallery.prev')}>‹</button>
      <img class="mv-lb-image" src="" alt="" decoding="async" />
      <button type="button" class="mv-lb-next" aria-label={t(locale, 'gallery.next')}>›</button>
    </dialog>
  </div>
)}

<!-- iter9 (п.5 YE): стили вьювера (.media-viewer/.mv-*) вынесены в
     src/styles/global.css — Astro бандлит <style> компонента только на
     страницы, где сам компонент отрендерен, а эта разметка нужна и на
     главной (модалка прототипов, PrototypeGrid.astro, собирает ее на
     клиенте через buildViewer() из media-viewer.js), где MediaViewer.astro
     не используется. См. подробный комментарий в global.css. -->

<script>
  // iter9 (п.5 YE): вся логика вьювера теперь в общем модуле — тот же
  // движок использует и модалка прототипов (PrototypeGrid.astro), которая
  // строит разметку на клиенте через buildViewer(). 3000мс — скорость
  // слайдшоу (картинки листаются по таймеру, видео/youtube — по концу
  // проигрывания, см. media-viewer.js).
  import { attachViewer } from '../scripts/media-viewer.js';

  document.querySelectorAll<HTMLElement>('.media-viewer').forEach((root) => {
    attachViewer(root, { slideshowMs: 3000 });
  });
</script>
