---
import { render } from 'astro:content';
import Base from '../layouts/Base.astro';
import MediaViewer from './MediaViewer.astro';
import { t, localePath, type Locale } from '../i18n/ui';
import { platformBadges } from '../lib/platforms';

const { locale, project } = Astro.props as { locale: Locale; project: any };
const d = project.data;
const { Content } = await render(project);
const slug = project.id.split('/')[1];
const badges = platformBadges(d.platforms, { pc: t(locale, 'platform.pc'), mobile: t(locale, 'platform.mobile') });
---
<Base locale={locale} title={`${d.title} — Aleksandr Kandakov`} description={d.tagline} path={`/projects/${slug}/`}>
  <article class="container section">
    <a href={localePath(locale, '/#projects')} class="mono">{t(locale, 'project.back')}</a>
    <h1 style="margin-top:.5em;">{d.title}</h1>
    <div class="mono" style="color:var(--muted);font-size:.85rem;margin-top:4px;">{d.genre}</div>
    <p style="color:var(--muted);font-size:1.1rem;">{d.tagline}</p>
    <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center;margin:10px 0 24px;">
      <span class="tag tag-violet">{d.company} · {d.role}</span>
      <span class="tag">{d.period}</span>
      {badges.map((b) => (
        <span class="platform-badge lg" set:html={b.svg + `<span>${b.label}</span>`} />
      ))}
    </div>
    <p style="display:flex;gap:12px;flex-wrap:wrap;align-items:center;margin:0 0 24px;">
      {d.links.map((l: any) => <a class="btn ghost" href={l.url}>{l.label}</a>)}
      <!-- iter10 (задача ZB, п.3): вторичная навигация на интерактивную карту,
           фокус сразу на этом проекте (deep-link #focus=<slug>, парсится в
           orbit.js: /^#focus=([a-z0-9-]+)$/) -->
      <a
        class="orbit-pin-link mono"
        href={`/orbit/#focus=${slug}`}
        title={locale === 'en' ? 'The map is in Russian' : undefined}
      >
        <svg class="orbit-pin-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <ellipse cx="12" cy="12" rx="9.5" ry="4.2" fill="none" stroke="currentColor" stroke-width="1.3" />
          <ellipse cx="12" cy="12" rx="4.2" ry="9.5" fill="none" stroke="currentColor" stroke-width="1.3" transform="rotate(55 12 12)" />
          <circle cx="12" cy="12" r="1.8" fill="currentColor" />
        </svg>
        {t(locale, 'project.showOnMap')}
      </a>
    </p>
    <MediaViewer locale={locale} slug={slug} title={d.title} youtube={d.youtube} />
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:14px;margin-bottom:24px;">
      <div class="info-card" style="background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:16px;">
        <div class="mono" style="color:var(--muted);font-size:.8rem;">{t(locale, 'project.role')}</div>
        <div style="font-weight:700;">{d.role}</div>
        <div class="mono" style="color:var(--ok);font-size:.9rem;margin-top:2px;">{d.metrics.join(' · ')}</div>
      </div>
      <div class="info-card" style="background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:16px;">
        <div class="mono" style="color:var(--muted);font-size:.8rem;">{t(locale, 'project.stack')}</div>
        <div style="display:flex;gap:6px;flex-wrap:wrap;margin-top:6px;">{d.stack.map((s: string) => <span class="tag tag-teal">{s}</span>)}</div>
      </div>
    </div>
    <Content />
  </article>
</Base>

<style>
  /* iter10 (задача ZB, п.3): деликатная пилюля вторичной навигации - тот же
     язык, что .icon-link (боковая иконка), но с подписью, приглушеннее btn.ghost */
  .orbit-pin-link {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 10px 16px; border-radius: var(--radius);
    border: 1px solid var(--border); color: var(--muted);
    font-size: .82rem; transition: border-color .2s, color .2s, transform .2s;
  }
  .orbit-pin-link:hover {
    color: var(--accent); border-color: var(--accent);
    transform: translateY(-2px); text-decoration: none;
  }
  .orbit-pin-icon { width: 18px; height: 18px; flex: none; }
</style>
