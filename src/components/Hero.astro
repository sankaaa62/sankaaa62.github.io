---
import { t, type Locale } from '../i18n/ui';
import SocialIcons from './SocialIcons.astro';
const { locale } = Astro.props as { locale: Locale };

const name: Record<Locale, string> = {
  en: 'Aleksandr Kandakov',
  ru: 'Александр Кандаков',
};
const firstRole = 'Senior Unity Developer';
// разбиваем имя на слова, слова на буквы: пробелы остаются обычными пробелами
// между nowrap-обертками, чтобы перенос строки был только по границе слова.
const words = name[locale].split(' ');
let letterCounter = 0;
const wordSpans = words.map((word) => {
  const letters = [...word].map((ch) => {
    const i = letterCounter++;
    return { ch, i };
  });
  return letters;
});
---
<section class="hero-section" style="position:relative;overflow:hidden;">
  <div class="container hero-stack" style="position:relative;z-index:1;">
    <div class="hero-portrait">
      <img
        src="/media/me.webp"
        alt={name[locale]}
        width="640"
        height="640"
        loading="eager"
        fetchpriority="high"
      />
    </div>
    <p class="mono hero-greeting">{t(locale, 'hero.greeting')}</p>
    <h1 class="hero-name" aria-label={name[locale]}>
      {wordSpans.map((letters) => (
        <span class="nowrap">
          {letters.map(({ ch, i }) => <span class="ltr" style={`--d:${i}`}>{ch}</span>)}
        </span>
      ))}
    </h1>
    <p class="mono hero-type-line">
      <span id="hero-type">{firstRole}</span><span class="hero-cursor" aria-hidden="true">▍</span>
    </p>
    <p class="hero-about">{t(locale, 'hero.about')}</p>
    <div class="hero-cta">
      <a class="btn sheen" href={locale === 'ru' ? '/cv/Kandakov_CV_ru.pdf' : '/cv/Kandakov_CV_en.pdf'} download>{t(locale, 'hero.cv')}</a>
      <SocialIcons />
    </div>
  </div>
  <button
    type="button"
    id="hero-scroll-cue"
    class="hero-scroll-cue"
    aria-label={t(locale, 'hero.scroll')}
  >
    <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
      <path d="M6 9l6 6 6-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>
</section>
<script src="../scripts/hero-type.js"></script>
<script src="../scripts/hero-scroll-cue.js"></script>
<script>
  // iter13 (задача CA, п.4): letter-shimmer (см. .ltr в style ниже) - бесконечная
  // анимация text-shadow+filter на 17 буквах, красится/paint'ится каждый кадр
  // ДАЖЕ когда hero давно проскроллен за пределы экрана. IntersectionObserver
  // ставит анимацию на паузу вне вьюпорта (класс .shimmer-paused - см. CSS,
  // паузит ТОЛЬКО letter-shimmer, разовая ltr-in не трогается) и снимает паузу
  // при возврате - мерцание просто продолжается с текущей фазы, не сбрасывается.
  const heroName = document.querySelector('.hero-name');
  if (heroName && 'IntersectionObserver' in window) {
    const io = new IntersectionObserver((entries) => {
      for (const e of entries) heroName.classList.toggle('shimmer-paused', !e.isIntersecting);
    }, { threshold: 0 });
    io.observe(heroName);
  }
</script>

<style>
  /* V.1: hero — полноэкранный слайд (высота вьюпорта минус шапка), контент
     по вертикальному центру. На мобильных (<720px) высота ослабляется до auto
     с комфортными паддингами, чтобы контент не обрезался на низких экранах. */
  .hero-section {
    min-height: calc(100vh - var(--header-h));
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  /* V.4: визитка-слайд — портрет над текстом по центру (avatar-first), весь
     контент в одну колонку, выровнен по центру. Заменяет прежнюю 2-колоночную
     сетку, чтобы убрать пустоту при коротком тексте/широких экранах. */
  .hero-stack {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 44px 20px 60px;
  }

  .hero-portrait {
    margin-bottom: 18px;
  }

  .hero-portrait img {
    width: 190px;
    height: 190px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid var(--accent);
    box-shadow: 0 0 40px rgba(255,92,26,.25);
    animation: portrait-float 6s ease-in-out infinite;
  }
  @keyframes portrait-float {
    0%, 100% { transform: translateY(-6px); }
    50% { transform: translateY(6px); }
  }

  .hero-greeting {
    color: var(--accent);
    margin: 0 0 6px;
  }

  .hero-name {
    margin: 0 0 12px;
  }

  .hero-type-line {
    margin: 0 0 16px;
    font-size: 1.1rem;
    color: var(--text);
  }
  @media (min-width: 720px) {
    .hero-type-line { min-width: 23ch; }
  }

  /* V.2: личный абзац под typewriter — воздушный, приглушенный, с мягким
     появлением после того, как имя уже дописалось буквами. */
  .hero-about {
    color: var(--muted);
    max-width: 64ch;
    font-size: .97rem;
    line-height: 1.62;
    margin: 0 auto 18px;
  }
  html.js .hero-about {
    opacity: 0;
    animation: hero-about-in .6s ease .5s forwards;
  }
  @keyframes hero-about-in {
    to { opacity: 1; }
  }

  .hero-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  /* V.3: ненавязчивый scroll-индикатор — призрачная круглая кнопка внизу по
     центру слайда, мягкий bounce, скрывается на очень низких вьюпортах. */
  .hero-scroll-cue {
    position: absolute;
    left: 50%;
    bottom: 20px;
    transform: translateX(-50%);
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid var(--border);
    background: rgba(23, 25, 34, .5);
    color: var(--muted);
    cursor: pointer;
    -webkit-backdrop-filter: blur(4px);
    backdrop-filter: blur(4px);
    transition: border-color .2s, color .2s, box-shadow .2s;
    animation: hero-cue-bounce 2s ease-in-out infinite;
  }
  .hero-scroll-cue:hover {
    color: var(--text);
    border-color: var(--accent);
    box-shadow: 0 0 14px rgba(255,92,26,.25);
  }
  .hero-scroll-cue:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  @keyframes hero-cue-bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(6px); }
  }
  @media (max-height: 560px) {
    .hero-scroll-cue { display: none; }
  }

  .hero-name .nowrap { white-space: nowrap; display: inline-block; }
  .hero-name .nowrap:not(:last-child) { margin-right: .28em; }

  /* V.6: буквы имени появляются letter-in (как раньше), а затем переходят в
     бесконечное "звездное" мерцание — легкая осцилляция яркости/text-shadow,
     десинхронизированная по буквам, чтобы не выглядеть неоновым морганием. */
  html.js .ltr {
    display: inline-block;
    opacity: 0;
    transform: translateY(8px);
    animation-name: ltr-in, letter-shimmer;
    animation-duration: .4s, 3.4s;
    animation-timing-function: ease, ease-in-out;
    animation-iteration-count: 1, infinite;
    animation-fill-mode: forwards, none;
    animation-delay: calc(var(--d) * 35ms), calc(var(--d) * 180ms + 1200ms);
  }
  html.js .ltr:nth-of-type(even) {
    animation-duration: .4s, 3.9s;
  }
  @keyframes ltr-in {
    to { opacity: 1; transform: none; }
  }
  @keyframes letter-shimmer {
    0%, 100% {
      text-shadow: 0 0 12px rgba(255,92,26,0);
      filter: brightness(1);
    }
    50% {
      text-shadow: 0 0 12px rgba(255,92,26,.35);
      filter: brightness(1.14);
    }
  }
  /* iter13 (задача CA, п.4): вне вьюпорта - пауза ТОЛЬКО у letter-shimmer
     (второе значение в списке анимаций .ltr); ltr-in (первое) остается running,
     ей и так играть один раз при появлении, пауза сюда бы ничего не изменила */
  html.js .hero-name.shimmer-paused .ltr {
    animation-play-state: running, paused;
  }
  .hero-cursor {
    color: var(--teal);
    font-weight: 700;
    animation: cursor-blink 1s step-start infinite;
  }
  @keyframes cursor-blink {
    50% { opacity: 0; }
  }

  @media (max-width: 720px) {
    .hero-section {
      min-height: auto;
    }
    .hero-stack {
      padding: 40px 20px 56px;
    }
    .hero-portrait {
      margin-bottom: 16px;
    }
    .hero-portrait img { width: 140px; height: 140px; }
  }
</style>
