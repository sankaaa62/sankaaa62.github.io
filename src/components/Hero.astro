---
import { t, type Locale } from '../i18n/ui';
import SocialIcons from './SocialIcons.astro';
const { locale } = Astro.props as { locale: Locale };

const name: Record<Locale, string> = {
  en: 'Aleksandr Kandakov',
  ru: 'Александр Кандаков',
};
const firstRole = 'Senior Unity Developer';
// разбиваем имя на слова, слова на буквы: пробелы остаются обычными пробелами
// между nowrap-обёртками, чтобы перенос строки был только по границе слова.
const words = name[locale].split(' ');
let letterCounter = 0;
const wordSpans = words.map((word) => {
  const letters = [...word].map((ch) => {
    const i = letterCounter++;
    return { ch, i };
  });
  return letters;
});
---
<section style="position:relative;overflow:hidden;">
  <canvas id="hero-canvas" style="position:absolute;inset:0;width:100%;height:100%;pointer-events:none;z-index:0;"></canvas>
  <div class="container hero-grid" style="position:relative;z-index:1;padding:96px 20px 72px;">
    <div class="hero-text">
      <p class="mono" style="color:var(--accent);margin:0;">{t(locale, 'hero.greeting')}</p>
      <h1 class="hero-name" aria-label={name[locale]}>
        {wordSpans.map((letters) => (
          <span class="nowrap">
            {letters.map(({ ch, i }) => <span class="ltr" style={`--d:${i}`}>{ch}</span>)}
          </span>
        ))}
      </h1>
      <p class="mono hero-type-line" style="font-size:1.1rem;color:var(--text);">
        <span id="hero-type">{firstRole}</span><span class="hero-cursor" aria-hidden="true">▍</span>
      </p>
      <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap;margin-top:24px;">
        <a class="btn" href={locale === 'ru' ? '/cv/Kandakov_CV_ru.pdf' : '/cv/Kandakov_CV_en.pdf'} download>{t(locale, 'hero.cv')}</a>
        <SocialIcons />
      </div>
    </div>
    <div class="hero-portrait">
      <img
        src="/media/me.webp"
        alt={name[locale]}
        width="640"
        height="640"
        loading="eager"
        fetchpriority="high"
      />
    </div>
  </div>
</section>
<script src="../scripts/hero-canvas.js"></script>
<script src="../scripts/hero-type.js"></script>

<style>
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 240px;
    gap: 40px;
    align-items: center;
  }

  .hero-text { min-width: 0; }

  .hero-name .nowrap { white-space: nowrap; display: inline-block; }
  .hero-name .nowrap:not(:last-child) { margin-right: .28em; }

  html.js .ltr {
    display: inline-block;
    opacity: 0;
    transform: translateY(8px);
    animation: ltr-in .4s forwards;
    animation-delay: calc(var(--d) * 35ms);
  }
  @keyframes ltr-in {
    to { opacity: 1; transform: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    html.js .ltr { opacity: 1; transform: none; animation: none; }
  }

  @media (min-width: 720px) {
    .hero-type-line { min-width: 23ch; }
  }

  .hero-cursor {
    color: var(--teal);
    font-weight: 700;
    animation: cursor-blink 1s step-start infinite;
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-cursor { animation: none; }
  }
  @keyframes cursor-blink {
    50% { opacity: 0; }
  }

  .hero-portrait {
    display: flex;
    justify-content: center;
  }

  .hero-portrait img {
    width: 240px;
    height: 240px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid var(--accent);
    box-shadow: 0 0 40px rgba(255,92,26,.25);
    animation: portrait-float 6s ease-in-out infinite;
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-portrait img { animation: none; }
  }
  @keyframes portrait-float {
    0%, 100% { transform: translateY(-6px); }
    50% { transform: translateY(6px); }
  }

  @media (max-width: 720px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }
    .hero-portrait { order: -1; }
    .hero-portrait img { width: 200px; height: 200px; }
  }
</style>
