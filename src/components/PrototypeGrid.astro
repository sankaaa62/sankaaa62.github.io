---
import { getCollection } from 'astro:content';
import { t, type Locale } from '../i18n/ui';
const { locale } = Astro.props as { locale: Locale };
const protos = (await getCollection('prototypes')).sort((a, b) => (b.data.pin ? 1 : 0) - (a.data.pin ? 1 : 0) || b.data.year - a.data.year);
---
<section id="prototypes" class="section container">
  <h2 class="reveal">{t(locale, 'prototypes.title')}</h2>
  <p style="color:var(--muted);">{t(locale, 'prototypes.sub')}</p>
  <div class="proto-carousel-wrap">
  <div class="proto-carousel">
    <div class="proto-fade proto-fade--left" aria-hidden="true"></div>
    <div class="proto-track">
      {protos.map((p, i) => (
        <div class="proto-card reveal" role="button" tabindex="0"
          data-id={p.data.id} data-title={p.data.title} data-genre={p.data.genre[locale]}
          data-year={p.data.year} data-clip={p.data.clip ? '1' : '0'} data-shots={p.data.shots}
          data-clip-full={p.data.clipFull ? '1' : '0'}
          data-link={p.data.link ?? ''}
          data-badge={p.data.badge ? p.data.badge[locale] : ''}
          style={`--i:${i};background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;cursor:pointer;`}>
          <div style="position:relative;aspect-ratio:1;">
            <img src={`/media/prototypes/${p.data.id}/icon.webp`} alt={p.data.title} loading="lazy"
                 style="width:100%;height:100%;object-fit:cover;" />
            {p.data.clip && (
              <video muted loop playsinline preload="none"
                poster={`/media/prototypes/${p.data.id}/poster.jpg`}
                style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:0;transition:opacity .25s;">
                <source src={`/media/prototypes/${p.data.id}/clip.webm`} type="video/webm" />
              </video>
            )}
            {p.data.badge && (
              <span class="proto-badge mono">{p.data.badge[locale]}</span>
            )}
          </div>
          <div style="padding:10px 12px;">
            <div style="font-weight:700;font-size:.92rem;">{p.data.title}</div>
            <div class="mono" style="color:var(--muted);font-size:.75rem;">{p.data.genre[locale]} · {p.data.year}</div>
          </div>
        </div>
      ))}
    </div>
    <div class="proto-fade proto-fade--right" aria-hidden="true"></div>
  </div>
  <div class="proto-nav">
    <button type="button" class="proto-nav-arrow proto-nav-arrow--prev" aria-label={t(locale, 'carousel.prev')}>‹</button>
    <div class="proto-dots" data-page-label={t(locale, 'carousel.page')}></div>
    <button type="button" class="proto-nav-arrow proto-nav-arrow--next" aria-label={t(locale, 'carousel.next')}>›</button>
  </div>
  </div>
</section>

<dialog id="proto-modal" data-store-label={t(locale, 'prototypes.store')}>
  <button type="button" class="pm-close" aria-label={t(locale, 'gallery.close')}>✕</button>
  <div class="pm-body">
    <div class="pm-head">
      <h3 class="pm-title"></h3>
      <span class="pm-badge mono" style="display:none;"></span>
    </div>
    <div class="mono pm-meta" style="color:var(--muted);"></div>
    <a class="pm-link btn ghost" target="_blank" rel="noopener" style="display:none;"></a>
    <video class="pm-video" controls autoplay muted loop playsinline style="display:none;"></video>
    <div class="pm-shots"></div>
    <img class="pm-icon" alt="" style="display:none;" />
  </div>
</dialog>

<style>
  #proto-modal {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
    color: var(--text);
    padding: 0;
    width: min(720px, 92vw);
    max-width: 720px;
    max-height: 90vh;
    position: fixed;
    inset: 0;
    margin: auto;
  }
  #proto-modal[open] {
    display: flex;
    flex-direction: column;
  }
  #proto-modal::backdrop {
    background: rgba(4, 5, 8, .88);
  }
  .pm-body {
    padding: 24px;
    overflow-y: auto;
  }
  .pm-head {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }
  .pm-title {
    margin: 0 0 4px;
  }
  .pm-badge {
    font-size: .7rem;
    padding: 3px 9px;
    border-radius: 999px;
    background: var(--accent);
    color: #0a0a0a;
    font-weight: 700;
    white-space: nowrap;
  }
  .pm-meta {
    font-size: .8rem;
    margin-bottom: 16px;
  }
  .pm-link {
    display: inline-flex;
    width: fit-content;
    margin-bottom: 16px;
    font-size: .85rem;
    padding: 8px 16px;
    text-decoration: none;
  }
  .proto-carousel {
    position: relative;
    margin-top: 4px;
  }
  .proto-track {
    display: flex;
    gap: 12px;
    overflow-x: auto;
    scroll-snap-type: x proximity;
    overscroll-behavior-x: contain;
    scrollbar-width: none;
    padding-bottom: 2px;
  }
  .proto-track::-webkit-scrollbar {
    display: none;
  }
  .proto-track .proto-card {
    flex: 0 0 200px;
    scroll-snap-align: start;
  }
  .proto-track .proto-card:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .proto-fade {
    position: absolute;
    top: 0;
    bottom: 2px;
    width: 32px;
    pointer-events: none;
    opacity: 0;
    transition: opacity .2s;
    z-index: 1;
  }
  .proto-fade--left {
    left: 0;
    background: linear-gradient(to right, var(--bg), transparent);
  }
  .proto-fade--right {
    right: 0;
    background: linear-gradient(to left, var(--bg), transparent);
  }
  .proto-fade.is-visible {
    opacity: 1;
  }
  .proto-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    margin-top: 16px;
  }
  .proto-nav-arrow {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 10px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text);
    font-size: 1.15rem;
    cursor: pointer;
    transition: transform .15s, border-color .15s, box-shadow .15s, opacity .15s;
  }
  .proto-nav-arrow:hover, .proto-nav-arrow:focus-visible {
    transform: translateY(-2px);
    border-color: var(--accent);
    box-shadow: 0 0 14px rgba(255,92,26,.3);
    outline: none;
  }
  .proto-nav-arrow:disabled {
    opacity: .3;
    cursor: default;
    box-shadow: none;
    transform: none;
  }
  .proto-dots {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 8px;
  }
  .proto-dot {
    width: 8px;
    height: 8px;
    padding: 0;
    border-radius: 50%;
    border: 1px solid var(--border);
    background: transparent;
    cursor: pointer;
    transition: transform .15s, background-color .15s, border-color .15s;
  }
  .proto-dot:hover {
    border-color: var(--accent);
  }
  .proto-dot:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .proto-dot.is-active {
    background: var(--accent);
    border-color: var(--accent);
    transform: scale(1.3);
  }
  .proto-badge {
    position: absolute;
    top: 8px;
    left: 8px;
    font-size: .62rem;
    padding: 2px 7px;
    border-radius: 999px;
    background: var(--accent);
    color: #0a0a0a;
    font-weight: 700;
    white-space: nowrap;
    z-index: 1;
  }
  .pm-video {
    display: block;
    width: 100%;
    max-height: 50vh;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    background: #000;
  }
  .pm-shots {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 10px;
    margin-top: 16px;
  }
  .pm-shots img {
    display: block;
    width: 100%;
    aspect-ratio: 16/9;
    object-fit: cover;
    border-radius: var(--radius);
    border: 1px solid var(--border);
  }
  .pm-icon {
    display: block;
    width: 100%;
    max-width: 320px;
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    margin: 0 auto;
  }
  .pm-close {
    position: fixed;
    top: 16px;
    right: 16px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 44px;
    min-height: 44px;
    border-radius: 12px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text);
    font-size: 1.4rem;
    cursor: pointer;
    transition: transform .15s, border-color .15s, box-shadow .15s;
  }
  .pm-close:hover, .pm-close:focus-visible {
    transform: translateY(-2px);
    border-color: var(--accent);
    box-shadow: 0 0 14px rgba(255,92,26,.3);
    outline: none;
  }

  @media (max-width: 640px) {
    #proto-modal {
      width: 100vw;
      max-width: 100vw;
      height: 100%;
      max-height: 100%;
      border-radius: 0;
    }
  }
</style>

<script>
  const protoWrap = document.querySelector<HTMLElement>('.proto-carousel-wrap');
  const protoTrack = document.querySelector<HTMLElement>('.proto-track');
  const protoFadeLeft = document.querySelector<HTMLElement>('.proto-fade--left');
  const protoFadeRight = document.querySelector<HTMLElement>('.proto-fade--right');
  const protoNavPrev = document.querySelector<HTMLButtonElement>('.proto-nav-arrow--prev');
  const protoNavNext = document.querySelector<HTMLButtonElement>('.proto-nav-arrow--next');
  const protoDots = document.querySelector<HTMLElement>('.proto-dots');
  const protoPageLabel = protoDots?.dataset.pageLabel ?? 'Page';

  const AUTOPLAY_MS = 4500;
  const GRACE_MS = 2000;
  const protoPauseReasons = new Set<string>();
  let protoAutoplayTimer: ReturnType<typeof setTimeout> | null = null;
  let protoGraceTimer: ReturnType<typeof setTimeout> | null = null;
  let protoCurrentPage = 0;
  let protoPageCount = 1;

  function protoClearAutoplayTimer() {
    if (protoAutoplayTimer !== null) { clearTimeout(protoAutoplayTimer); protoAutoplayTimer = null; }
  }
  function protoClearGraceTimer() {
    if (protoGraceTimer !== null) { clearTimeout(protoGraceTimer); protoGraceTimer = null; }
  }
  function protoScheduleAdvance() {
    protoClearAutoplayTimer();
    protoAutoplayTimer = setTimeout(protoAdvance, AUTOPLAY_MS);
  }
  function protoAdvance() {
    if (!protoTrack || protoPauseReasons.size > 0) return;
    if (protoPageCount <= 1) { protoScheduleAdvance(); return; }
    if (protoCurrentPage >= protoPageCount - 1) {
      protoTrack.scrollTo({ left: 0, behavior: 'smooth' });
      protoCurrentPage = 0;
      protoUpdateActiveDot();
      protoUpdateArrows();
    } else {
      protoGoToPage(protoCurrentPage + 1, false);
    }
    protoScheduleAdvance();
  }
  function pauseCarousel(reason: string) {
    protoPauseReasons.add(reason);
    protoClearGraceTimer();
    protoClearAutoplayTimer();
  }
  function resumeCarousel(reason: string, grace = true) {
    protoPauseReasons.delete(reason);
    if (protoPauseReasons.size > 0) return;
    protoClearGraceTimer();
    if (grace) {
      protoGraceTimer = setTimeout(() => {
        protoGraceTimer = null;
        if (protoPauseReasons.size === 0) protoScheduleAdvance();
      }, GRACE_MS);
    } else {
      protoScheduleAdvance();
    }
  }

  function protoComputePageCount(): number {
    if (!protoTrack || protoTrack.clientWidth <= 0) return 1;
    return Math.max(1, Math.ceil(protoTrack.scrollWidth / protoTrack.clientWidth));
  }

  function protoBuildDots() {
    if (!protoDots) return;
    protoDots.innerHTML = '';
    for (let i = 0; i < protoPageCount; i++) {
      const dot = document.createElement('button');
      dot.type = 'button';
      dot.className = 'proto-dot';
      dot.setAttribute('aria-label', `${protoPageLabel} ${i + 1}`);
      dot.dataset.page = String(i);
      dot.addEventListener('click', () => protoGoToPage(i, true));
      protoDots.appendChild(dot);
    }
    protoUpdateActiveDot();
  }

  function protoUpdateActiveDot() {
    if (!protoDots) return;
    protoDots.querySelectorAll<HTMLElement>('.proto-dot').forEach((dot, i) => {
      const active = i === protoCurrentPage;
      dot.classList.toggle('is-active', active);
      if (active) dot.setAttribute('aria-current', 'true');
      else dot.removeAttribute('aria-current');
    });
  }

  function protoUpdateArrows() {
    if (protoNavPrev) protoNavPrev.disabled = protoCurrentPage <= 0;
    if (protoNavNext) protoNavNext.disabled = protoCurrentPage >= protoPageCount - 1;
  }

  function protoUpdateFades() {
    if (!protoTrack) return;
    const maxScroll = protoTrack.scrollWidth - protoTrack.clientWidth;
    const atStart = protoTrack.scrollLeft <= 2;
    const atEnd = protoTrack.scrollLeft >= maxScroll - 2;
    protoFadeLeft?.classList.toggle('is-visible', !atStart && maxScroll > 0);
    protoFadeRight?.classList.toggle('is-visible', !atEnd && maxScroll > 0);
  }

  function protoGoToPage(page: number, userInitiated: boolean) {
    if (!protoTrack) return;
    const clamped = Math.min(Math.max(page, 0), protoPageCount - 1);
    protoCurrentPage = clamped;
    protoTrack.scrollTo({ left: clamped * protoTrack.clientWidth, behavior: 'smooth' });
    protoUpdateActiveDot();
    protoUpdateArrows();
    if (userInitiated && protoPauseReasons.size === 0) {
      protoScheduleAdvance();
    }
  }

  function protoRefreshLayout() {
    if (!protoTrack) return;
    protoPageCount = protoComputePageCount();
    const maxScroll = protoTrack.scrollWidth - protoTrack.clientWidth;
    protoCurrentPage = maxScroll > 0
      ? Math.min(Math.round(protoTrack.scrollLeft / protoTrack.clientWidth), protoPageCount - 1)
      : 0;
    protoBuildDots();
    protoUpdateArrows();
    protoUpdateFades();
  }

  if (protoTrack) {
    protoRefreshLayout();

    let protoScrollRaf = 0;
    protoTrack.addEventListener('scroll', () => {
      if (protoScrollRaf) return;
      protoScrollRaf = requestAnimationFrame(() => {
        protoScrollRaf = 0;
        if (!protoTrack) return;
        const cw = protoTrack.clientWidth || 1;
        const page = Math.round(protoTrack.scrollLeft / cw);
        protoCurrentPage = Math.min(Math.max(page, 0), protoPageCount - 1);
        protoUpdateActiveDot();
        protoUpdateArrows();
        protoUpdateFades();
      });
    }, { passive: true });

    window.addEventListener('resize', protoRefreshLayout);

    protoNavPrev?.addEventListener('click', () => protoGoToPage(protoCurrentPage - 1, true));
    protoNavNext?.addEventListener('click', () => protoGoToPage(protoCurrentPage + 1, true));

    protoScheduleAdvance();

    protoWrap?.addEventListener('pointerenter', () => pauseCarousel('hover'));
    protoWrap?.addEventListener('pointerleave', () => resumeCarousel('hover', true));
    protoWrap?.addEventListener('pointerdown', () => pauseCarousel('drag'));
    window.addEventListener('pointerup', () => resumeCarousel('drag', true));
    window.addEventListener('pointercancel', () => resumeCarousel('drag', true));

    document.addEventListener('visibilitychange', () => {
      if (document.hidden) pauseCarousel('tab');
      else resumeCarousel('tab', false);
    });
    if (document.hidden) pauseCarousel('tab');

    if (protoWrap && 'IntersectionObserver' in window) {
      const protoIo = new IntersectionObserver((entries) => {
        const entry = entries[0];
        if (!entry) return;
        if (entry.isIntersecting) resumeCarousel('viewport', false);
        else pauseCarousel('viewport');
      }, { threshold: 0.1 });
      protoIo.observe(protoWrap);
    }
  }

  if (matchMedia('(hover: hover) and (pointer: fine)').matches) {
    document.querySelectorAll('.proto-card').forEach((card) => {
      const el = card as HTMLElement;
      el.style.transition = 'opacity .6s, transform .15s ease-out';
      const video = el.querySelector('video');
      el.addEventListener('pointerenter', () => {
        if (video) { video.style.opacity = '1'; video.play().catch(() => {}); }
      });
      el.addEventListener('pointerleave', () => {
        if (video) { video.style.opacity = '0'; video.pause(); }
        el.style.transform = '';
      });
      el.addEventListener('pointermove', (e) => {
        const ev = e as PointerEvent;
        const r = el.getBoundingClientRect();
        const x = (ev.clientX - r.left) / r.width - 0.5;
        const y = (ev.clientY - r.top) / r.height - 0.5;
        el.style.transform = `perspective(600px) rotateY(${x * 6}deg) rotateX(${-y * 6}deg) scale(1.03)`;
      });
    });
  }

  const modal = document.querySelector<HTMLDialogElement>('#proto-modal');
  if (modal) {
    const closeBtn = modal.querySelector<HTMLButtonElement>('.pm-close');
    const titleEl = modal.querySelector<HTMLElement>('.pm-title');
    const badgeEl = modal.querySelector<HTMLElement>('.pm-badge');
    const metaEl = modal.querySelector<HTMLElement>('.pm-meta');
    const linkEl = modal.querySelector<HTMLAnchorElement>('.pm-link');
    const videoEl = modal.querySelector<HTMLVideoElement>('.pm-video');
    const shotsEl = modal.querySelector<HTMLElement>('.pm-shots');
    const iconEl = modal.querySelector<HTMLImageElement>('.pm-icon');
    const storeLabel = modal.dataset.storeLabel ?? 'View on Google Play';
    let previousOverflow = '';
    let lastCard: HTMLElement | null = null;

    const openModal = (card: HTMLElement) => {
      lastCard = card;
      const id = card.dataset.id ?? '';
      const title = card.dataset.title ?? '';
      const genre = card.dataset.genre ?? '';
      const year = card.dataset.year ?? '';
      const hasClip = card.dataset.clip === '1';
      const hasClipFull = card.dataset.clipFull === '1';
      const shots = Number(card.dataset.shots ?? '0');
      const link = card.dataset.link ?? '';
      const badge = card.dataset.badge ?? '';

      if (titleEl) titleEl.textContent = title;
      if (badgeEl) {
        if (badge) { badgeEl.textContent = badge; badgeEl.style.display = 'inline-flex'; }
        else { badgeEl.style.display = 'none'; }
      }
      if (metaEl) metaEl.textContent = `${genre} · ${year}`;
      if (linkEl) {
        if (link) {
          linkEl.href = link;
          linkEl.textContent = storeLabel;
          linkEl.style.display = 'inline-flex';
        } else {
          linkEl.style.display = 'none';
          linkEl.removeAttribute('href');
        }
      }

      if (videoEl) {
        if (hasClip) {
          videoEl.poster = `/media/prototypes/${id}/poster.jpg`;
          videoEl.src = `/media/prototypes/${id}/${hasClipFull ? 'clip-full.webm' : 'clip.webm'}`;
          videoEl.style.display = 'block';
        } else {
          videoEl.style.display = 'none';
          videoEl.removeAttribute('src');
          videoEl.load();
        }
      }

      if (shotsEl) {
        shotsEl.innerHTML = '';
        if (shots > 0) {
          for (let i = 1; i <= shots; i++) {
            const img = document.createElement('img');
            img.src = `/media/prototypes/${id}/shots/${i}.webp`;
            img.alt = `${title} — screenshot ${i}`;
            img.loading = 'lazy';
            shotsEl.appendChild(img);
          }
        }
      }

      if (iconEl) {
        if (!hasClip && shots === 0) {
          iconEl.src = `/media/prototypes/${id}/icon.webp`;
          iconEl.alt = title;
          iconEl.style.display = 'block';
        } else {
          iconEl.style.display = 'none';
          iconEl.src = '';
        }
      }

      if (!modal!.open) {
        previousOverflow = document.body.style.overflow;
        document.body.style.overflow = 'hidden';
        modal!.showModal();
        pauseCarousel('modal');
      }
      if (hasClip && videoEl) {
        videoEl.play().catch(() => {});
      }
    };

    document.querySelectorAll<HTMLElement>('.proto-card').forEach((card) => {
      card.addEventListener('click', () => openModal(card));
      card.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          openModal(card);
        }
      });
    });

    closeBtn?.addEventListener('click', () => modal.close());

    modal.addEventListener('click', (e) => {
      if (e.target === modal) modal.close();
    });

    modal.addEventListener('close', () => {
      if (videoEl) {
        videoEl.pause();
        videoEl.removeAttribute('src');
        videoEl.load();
      }
      document.body.style.overflow = previousOverflow;
      if (lastCard) {
        const v = lastCard.querySelector('video');
        if (v) { v.style.opacity = '0'; v.pause(); }
        lastCard.style.transform = '';
        lastCard = null;
      }
      resumeCarousel('modal', true);
    });
  }
</script>
