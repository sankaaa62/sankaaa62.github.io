---
import { getCollection } from 'astro:content';
import { t, type Locale } from '../i18n/ui';
const { locale } = Astro.props as { locale: Locale };
const protos = (await getCollection('prototypes')).sort((a, b) => (b.data.pin ? 1 : 0) - (a.data.pin ? 1 : 0) || b.data.year - a.data.year);
---
<div id="prototypes" class="proto-section">
  <p class="mono" style="color:var(--muted);font-size:.85rem;">{t(locale, 'prototypes.sub')}</p>
  <div class="proto-carousel-wrap">
  <div class="proto-carousel">
    <div class="proto-fade proto-fade--left" aria-hidden="true"></div>
    <div class="proto-track">
      {[...protos, ...protos].map((p, i) => {
        const isClone = i >= protos.length;
        return (
        <div class={isClone ? 'proto-card' : 'proto-card reveal'}
          role="button" tabindex={isClone ? undefined : 0} aria-hidden={isClone ? 'true' : undefined}
          data-id={p.data.id} data-title={p.data.title} data-genre={p.data.genre[locale]}
          data-year={p.data.year} data-clip={p.data.clip ? '1' : '0'} data-shots={p.data.shots}
          data-clip-full={p.data.clipFull ? '1' : '0'}
          data-extra-clips={p.data.extraClips}
          data-link={p.data.link ?? ''}
          data-badge={p.data.badge ? p.data.badge[locale] : ''}
          style={`--i:${isClone ? 0 : i};background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;cursor:pointer;`}>
          <div style="position:relative;aspect-ratio:1;">
            <img src={`/media/prototypes/${p.data.id}/icon.webp`} alt={p.data.title} loading="lazy"
                 draggable="false"
                 style="width:100%;height:100%;object-fit:cover;" />
            {p.data.clip && (
              <video muted loop playsinline preload="none"
                poster={`/media/prototypes/${p.data.id}/poster.jpg`}
                style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:0;transition:opacity .25s;">
                <source src={`/media/prototypes/${p.data.id}/clip.webm`} type="video/webm" />
              </video>
            )}
            {p.data.badge && (
              <span class="proto-badge mono">{p.data.badge[locale]}</span>
            )}
          </div>
          <div style="padding:10px 12px;">
            <div style="font-weight:700;font-size:.92rem;">{p.data.title}</div>
            <div class="mono" style="color:var(--muted);font-size:.75rem;">{p.data.genre[locale]} · {p.data.year}</div>
          </div>
        </div>
        );
      })}
    </div>
    <div class="proto-fade proto-fade--right" aria-hidden="true"></div>
  </div>
  <div class="proto-nav">
    <button type="button" class="proto-nav-arrow proto-nav-arrow--prev" aria-label={t(locale, 'carousel.prev')}>‹</button>
    <button type="button" class="proto-nav-arrow proto-nav-arrow--next" aria-label={t(locale, 'carousel.next')}>›</button>
  </div>
  </div>
</div>

<dialog id="proto-modal" data-store-label={t(locale, 'prototypes.store')}>
  <button type="button" class="pm-close" aria-label={t(locale, 'gallery.close')}>✕</button>
  <div class="pm-body">
    <div class="pm-head">
      <h3 class="pm-title"></h3>
      <span class="pm-badge mono" style="display:none;"></span>
    </div>
    <div class="mono pm-meta" style="color:var(--muted);"></div>
    <a class="pm-link btn ghost" target="_blank" rel="noopener" style="display:none;"></a>
    <video class="pm-video" controls autoplay muted loop playsinline style="display:none;"></video>
    <div class="pm-extra-clips"></div>
    <div class="pm-shots"></div>
    <img class="pm-icon" alt="" style="display:none;" />
  </div>
</dialog>

<style>
  /* iter9 (п.3): отступ от карточек "Проектов" сверху — секция-родитель
     теперь общая (#projects), свой .section/.container не нужен (иначе
     двойной вертикальный паддинг), но зазор от карточек все равно нужен. */
  .proto-section {
    margin-top: 48px;
  }

  #proto-modal {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
    color: var(--text);
    padding: 0;
    width: min(720px, 92vw);
    max-width: 720px;
    max-height: 90vh;
    position: fixed;
    inset: 0;
    margin: auto;
  }
  #proto-modal[open] {
    display: flex;
    flex-direction: column;
  }
  #proto-modal::backdrop {
    background: rgba(4, 5, 8, .88);
  }
  .pm-body {
    padding: 24px;
    overflow-y: auto;
  }
  .pm-head {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }
  .pm-title {
    margin: 0 0 4px;
  }
  .pm-badge {
    font-size: .7rem;
    padding: 3px 9px;
    border-radius: 999px;
    background: var(--accent);
    color: #0a0a0a;
    font-weight: 700;
    white-space: nowrap;
  }
  .pm-meta {
    font-size: .8rem;
    margin-bottom: 16px;
  }
  .pm-link {
    display: inline-flex;
    width: fit-content;
    margin-bottom: 16px;
    font-size: .85rem;
    padding: 8px 16px;
    text-decoration: none;
  }
  .proto-carousel {
    position: relative;
    margin-top: 4px;
  }
  .proto-track {
    display: flex;
    gap: 12px;
    overflow-x: auto;
    overflow-y: visible;
    overscroll-behavior-x: contain;
    scrollbar-width: none;
    touch-action: pan-x;
    padding: 18px 0;
    cursor: grab;
    /* iter8 фикс: раньше от нативного выделения текста при драге спасались
       через ev.preventDefault() в pointerdown — но по спеке Pointer Events
       preventDefault() на pointerdown ГАСИТ последующие compatibility mouse
       events, включая click (см. комментарий у pointerdown-слушателя ниже).
       Правильный паттерн — не трогать preventDefault, а запретить выделение
       через CSS */
    user-select: none;
    -webkit-user-select: none;
  }
  /* курсор карточек — inline style="cursor:pointer" на самом элементе
     карточки (см. map() выше) — он всегда выигрывает у унаследованного
     grab с трека, так что кликабельность визуально не теряется */
  .proto-track.is-dragging {
    cursor: grabbing;
  }
  .proto-track::-webkit-scrollbar {
    display: none;
  }
  /* iter8: запрет нативного drag-n-drop картинок (иначе браузер норовит
     начать перетаскивание <img> как файл поверх нашего pointer-based драга) */
  .proto-track img {
    -webkit-user-drag: none;
    user-drag: none;
  }
  .proto-track .proto-card {
    flex: 0 0 200px;
    transition: transform .25s ease-out;
  }
  /* карточки внутри marquee-трека появляются только затуханием — без
     вертикального translateY из общего .reveal: с непрерывным горизонтальным
     скроллом карточки, что еще не попадали во вьюпорт, будут постоянно
     "приезжать" в состояние translateY(24px), и этот трансформ считается в
     scrollHeight трека, создавая паразитную вертикальную прокрутку секции */
  .proto-track .proto-card.reveal {
    transform: none;
  }
  .proto-track .proto-card:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .proto-track .proto-card.spread-left {
    transform: translateX(-10px);
  }
  .proto-track .proto-card.spread-right {
    transform: translateX(10px);
  }
  .proto-fade {
    position: absolute;
    top: 0;
    bottom: 2px;
    width: 32px;
    pointer-events: none;
    opacity: 0;
    transition: opacity .2s;
    z-index: 1;
  }
  .proto-fade--left {
    left: 0;
    background: linear-gradient(to right, var(--bg), transparent);
  }
  .proto-fade--right {
    right: 0;
    background: linear-gradient(to left, var(--bg), transparent);
  }
  .proto-fade.is-visible {
    opacity: 1;
  }
  .proto-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    margin-top: 16px;
  }
  .proto-nav-arrow {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 10px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text);
    font-size: 1.15rem;
    cursor: pointer;
    transition: transform .15s, border-color .15s, box-shadow .15s, opacity .15s;
  }
  .proto-nav-arrow:hover, .proto-nav-arrow:focus-visible {
    transform: translateY(-2px);
    border-color: var(--accent);
    box-shadow: 0 0 14px rgba(255,92,26,.3);
    outline: none;
  }
  .proto-badge {
    position: absolute;
    top: 8px;
    left: 8px;
    font-size: .62rem;
    padding: 2px 7px;
    border-radius: 999px;
    background: var(--accent);
    color: #0a0a0a;
    font-weight: 700;
    white-space: nowrap;
    z-index: 1;
  }
  .pm-video {
    display: block;
    width: 100%;
    max-height: 50vh;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    background: #000;
  }
  .pm-extra-clips {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-top: 12px;
  }
  .pm-extra-clips video {
    display: block;
    width: 100%;
    max-height: 40vh;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    background: #000;
  }
  .pm-shots {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 10px;
    margin-top: 16px;
  }
  .pm-shots img {
    display: block;
    width: 100%;
    aspect-ratio: 16/9;
    object-fit: cover;
    border-radius: var(--radius);
    border: 1px solid var(--border);
  }
  .pm-icon {
    display: block;
    width: 100%;
    max-width: 320px;
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    margin: 0 auto;
  }
  .pm-close {
    position: fixed;
    top: 16px;
    right: 16px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 44px;
    min-height: 44px;
    border-radius: 12px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text);
    font-size: 1.4rem;
    cursor: pointer;
    transition: transform .15s, border-color .15s, box-shadow .15s;
  }
  .pm-close:hover, .pm-close:focus-visible {
    transform: translateY(-2px);
    border-color: var(--accent);
    box-shadow: 0 0 14px rgba(255,92,26,.3);
    outline: none;
  }

  @media (max-width: 640px) {
    #proto-modal {
      width: 100vw;
      max-width: 100vw;
      height: 100%;
      max-height: 100%;
      border-radius: 0;
    }
  }
</style>

<script>
  const protoWrap = document.querySelector<HTMLElement>('.proto-carousel-wrap');
  const protoTrack = document.querySelector<HTMLElement>('.proto-track');
  const protoFadeLeft = document.querySelector<HTMLElement>('.proto-fade--left');
  const protoFadeRight = document.querySelector<HTMLElement>('.proto-fade--right');
  const protoNavPrev = document.querySelector<HTMLButtonElement>('.proto-nav-arrow--prev');
  const protoNavNext = document.querySelector<HTMLButtonElement>('.proto-nav-arrow--next');

  // iter6 Задача FF: непрерывный marquee вместо постраничного автоплея.
  // Последовательность карточек в разметке продублирована один раз (клоны
  // aria-hidden, без tabindex, без .reveal — см. PrototypeGrid.astro map()),
  // так что бесшовный цикл — это просто scrollLeft, обернутый по ширине
  // оригинальной последовательности.
  const PROTO_SPEED_PX_S = 35;
  const PROTO_SCROLL_GRACE_MS = 2500;
  const protoPauseReasons = new Set<string>();
  let protoOriginalWidth = 0;
  let protoLastTs = 0;
  // флаг (не таймер!) — тикер выставляет true перед своей записью в scrollLeft,
  // слушатель 'scroll' гасит ОДНО следующее событие и сбрасывает флаг. Таймер-
  // окно здесь не работает: тикер пишет каждый кадр (~16мс), и скользящее окно
  // в 80мс никогда бы не успевало закрыться, маскируя все пользовательские скроллы.
  let protoIsMarqueeWrite = false;
  let protoUserScrollTimer: ReturnType<typeof setTimeout> | null = null;
  let protoResizeTimer: ReturnType<typeof setTimeout> | null = null;
  // отдельный float-аккумулятор: scrollLeft у некоторых движков округляется
  // при чтении, а прирост за кадр (~35px/60fps ≈ 0.6px) на таком округлении
  // тонет — позиция никогда не сдвигается, если считать от el.scrollLeft
  let protoScrollAccum = 0;

  // iter7 Задача NN: drag-скролл трека мышкой. Гейт по pointerType === 'mouse' —
  // тач-свайп идет нативным путем (touch-action: pan-x на треке, см. стили),
  // здесь его не трогаем. Пауза 'drag' на время драга уже вешается общим
  // pointerdown-слушателем на protoWrap ниже; наши записи в scrollLeft НЕ
  // помечаются protoMarkProgrammatic(), поэтому естественно рождают событие
  // 'scroll' → protoScheduleUserScrollResume() → аккумулятор ресинкается
  // с реальным scrollLeft, когда 'user-scroll' снимется по грации — тот же
  // путь, что и для колеса/тач-свайпа, ничего специального добавлять не нужно.
  const PROTO_DRAG_CLICK_SUPPRESS_PX = 6;
  let protoDragActive = false;
  let protoDragStartX = 0;
  let protoDragStartScroll = 0;
  let protoDragDistance = 0;

  // iter8 Задача: инерция драга мышкой после отпускания. Скорость считаем по
  // последним сэмплам scrollLeft (не clientX!) — так знак v сразу совпадает
  // с направлением, в котором надо продолжать писать в scrollLeft.
  const PROTO_MOMENTUM_SAMPLES = 4; // последние N точек => N-1 дельт скорости
  const PROTO_MOMENTUM_DECAY_PER_FRAME = 0.94; // на кадр ~16.67мс, см. protoMomentumTick
  const PROTO_MOMENTUM_MIN_V = 0.05; // px/ms — и порог запуска, и порог остановки (по спеке)
  let protoDragSamples: { t: number; x: number }[] = [];
  let protoMomentumActive = false;
  let protoMomentumV = 0;
  let protoMomentumLastTs = 0;

  function pauseCarousel(reason: string) {
    protoPauseReasons.add(reason);
  }
  function resumeCarousel(reason: string) {
    protoPauseReasons.delete(reason);
    if (protoPauseReasons.size === 0) {
      // сброс базовой временной метки, чтобы после долгой паузы (скрытая
      // вкладка, вне вьюпорта) не случился скачок на большой dt, и ресинк
      // аккумулятора с реальным scrollLeft (могло сместиться пользователем)
      protoLastTs = 0;
      if (protoTrack) protoScrollAccum = protoTrack.scrollLeft;
    }
  }

  // помечает ближайшую запись в scrollLeft как программную (не пользовательскую)
  function protoMarkProgrammatic() {
    protoIsMarqueeWrite = true;
  }

  function protoScheduleUserScrollResume() {
    pauseCarousel('user-scroll');
    if (protoUserScrollTimer) clearTimeout(protoUserScrollTimer);
    protoUserScrollTimer = setTimeout(() => {
      protoUserScrollTimer = null;
      resumeCarousel('user-scroll');
    }, PROTO_SCROLL_GRACE_MS);
  }

  function protoMeasure() {
    if (!protoTrack) return;
    const cards = Array.from(protoTrack.children) as HTMLElement[];
    const half = Math.floor(cards.length / 2);
    const firstClone = cards[half];
    if (!firstClone) { protoOriginalWidth = protoTrack.scrollWidth; return; }
    const trackRect = protoTrack.getBoundingClientRect();
    const cloneRect = firstClone.getBoundingClientRect();
    // расстояние от левого края трека до первого клона в системе координат
    // контента (не зависит от текущего scrollLeft на момент замера)
    protoOriginalWidth = (cloneRect.left - trackRect.left) + protoTrack.scrollLeft;
  }

  function protoCardStep(): number {
    if (!protoTrack) return 0;
    const first = protoTrack.querySelector<HTMLElement>('.proto-card');
    if (!first) return 0;
    const style = getComputedStyle(protoTrack);
    const gap = parseFloat(style.columnGap || style.gap || '0') || 0;
    return first.getBoundingClientRect().width + gap;
  }

  // если для смещения на distance не хватает места до края скролла — заранее
  // (незаметно, т.к. содержимое дублировано) сдвигает окно на originalWidth
  function protoEnsureHeadroom(direction: 1 | -1, distance: number) {
    if (!protoTrack || protoOriginalWidth <= 0) return;
    const maxScroll = protoTrack.scrollWidth - protoTrack.clientWidth;
    if (direction < 0 && protoTrack.scrollLeft - distance < 0) {
      protoMarkProgrammatic();
      protoTrack.scrollLeft += protoOriginalWidth;
    } else if (direction > 0 && protoTrack.scrollLeft + distance > maxScroll) {
      protoMarkProgrammatic();
      protoTrack.scrollLeft -= protoOriginalWidth;
    }
  }

  function protoTick(ts: number) {
    requestAnimationFrame(protoTick);
    if (!protoTrack || protoOriginalWidth <= 0) return;
    if (!protoLastTs) { protoLastTs = ts; return; }
    const dt = Math.min((ts - protoLastTs) / 1000, 0.1);
    protoLastTs = ts;
    if (protoPauseReasons.size > 0) return;
    protoScrollAccum += PROTO_SPEED_PX_S * dt;
    if (protoScrollAccum >= protoOriginalWidth) {
      protoScrollAccum -= protoOriginalWidth;
    }
    protoMarkProgrammatic();
    protoTrack.scrollLeft = protoScrollAccum;
  }

  if (protoTrack) {
    protoMeasure();
    protoScrollAccum = protoTrack.scrollLeft;
    protoFadeLeft?.classList.add('is-visible');
    protoFadeRight?.classList.add('is-visible');
    // стартуем на паузе «вне вьюпорта» — IntersectionObserver снимет ее,
    // как только подтвердит видимость секции
    pauseCarousel('viewport');
    requestAnimationFrame(protoTick);

    protoTrack.addEventListener('scroll', () => {
      if (protoIsMarqueeWrite) { protoIsMarqueeWrite = false; return; }
      // скролл вызван пользователем (свайп/колесо/клик по стрелке) —
      // пауза + грация 2.5с после последнего такого события
      protoScheduleUserScrollResume();
    }, { passive: true });

    // колесо мыши не порождает pointerdown — ловим его отдельно, чтобы пауза
    // включилась раньше, чем прилетит событие scroll (иначе возможна гонка
    // с флагом protoIsMarqueeWrite, если тикер как раз пишет в этот же кадр)
    protoTrack.addEventListener('wheel', () => protoScheduleUserScrollResume(), { passive: true });

    // drag-скролл мышкой (iter7). pointerType-гейт держит тач нетронутым —
    // нативный pan-x скролл продолжает работать как раньше.
    protoTrack.addEventListener('pointerdown', (e) => {
      if (!protoTrack) return;
      const ev = e as PointerEvent;
      protoDragDistance = 0;
      // новый жест обрывает предыдущую инерцию (если пользователь ловит
      // едущий по инерции трек рукой)
      protoMomentumActive = false;
      if (ev.pointerType !== 'mouse' || ev.button !== 0) return;
      protoDragActive = true;
      protoDragStartX = ev.clientX;
      protoDragStartScroll = protoTrack.scrollLeft;
      protoDragSamples = [{ t: ev.timeStamp, x: protoTrack.scrollLeft }];
      protoTrack.classList.add('is-dragging');
      // ВАЖНО (iter8, root cause бага "клик не открывает модалку" — 2 части):
      // 1) раньше тут стоял ev.preventDefault() — по спеке Pointer Events это
      //    гасит синтезируемые compatibility mouse events, В ТОМ ЧИСЛЕ 'click',
      //    для ЛЮБОГО клика мышью (не только после реального драга). Выделение
      //    текста теперь блокируется через CSS (user-select: none на .proto-track,
      //    -webkit-user-drag: none + draggable="false" на img — см. стили выше)
      //    вместо preventDefault.
      // 2) setPointerCapture() РАНЬШЕ вызывался прямо тут, безусловно на каждый
      //    pointerdown. По спеке Pointer Events захват указателя ретаргетит
      //    compatibility mouse events (в т.ч. click) НА элемент захвата — т.е.
      //    click при отпускании стал таргетиться на protoTrack, а не на
      //    карточку. Поскольку карточка — потомок protoTrack, событие в этом
      //    случае вообще не проходит через ее bubble-листенер (клик не
      //    всплывает К потомкам, только ОТ таргета вверх) — card.click()
      //    просто никогда не срабатывал. Проверено вживую: даже без
      //    preventDefault клик долетал до protoTrack, а не до карточки.
      //    Исправлено ниже — захват указателя теперь ЛЕНИВЫЙ: включается
      //    только когда движение подтверждает реальный драг (после порога
      //    PROTO_DRAG_CLICK_SUPPRESS_PX). Для обычного клика без движения
      //    capture вообще не включается — click естественно доходит до
      //    карточки и открывает модалку.
    });

    protoTrack.addEventListener('pointermove', (e) => {
      if (!protoTrack || !protoDragActive) return;
      const ev = e as PointerEvent;
      const dx = ev.clientX - protoDragStartX;
      const wasDrag = protoDragDistance > PROTO_DRAG_CLICK_SUPPRESS_PX;
      protoDragDistance = Math.max(protoDragDistance, Math.abs(dx));
      // ленивый захват указателя — см. комментарий у pointerdown выше. try/catch
      // защищает от редкого InvalidPointerId (указатель уже отпущен/невалиден
      // к моменту вызова) — без него необработанное исключение оборвало бы
      // остаток этого обработчика, потеряв запись scrollLeft для этого кадра
      if (!wasDrag && protoDragDistance > PROTO_DRAG_CLICK_SUPPRESS_PX && !protoTrack.hasPointerCapture(ev.pointerId)) {
        try { protoTrack.setPointerCapture(ev.pointerId); } catch { /* noop */ }
      }
      // пишем НЕ через protoMarkProgrammatic() — это настоящий пользовательский
      // скролл, событие 'scroll' должно пройти обычным путем (пауза + грация +
      // ресинк аккумулятора при резюме, см. комментарий у объявления переменных)
      protoTrack.scrollLeft = protoDragStartScroll - dx;
      protoDragSamples.push({ t: ev.timeStamp, x: protoTrack.scrollLeft });
      if (protoDragSamples.length > PROTO_MOMENTUM_SAMPLES) protoDragSamples.shift();
    });

    // decay-анимация инерции: пишем в scrollLeft каждый кадр (тоже НЕ через
    // protoMarkProgrammatic — событие 'scroll' само продлевает грацию
    // 'user-scroll', пока идет инерция; когда инерция останавливается,
    // последнее такое событие запускает обычные 2.5с грации → резюм marquee,
    // см. комментарий у protoScheduleUserScrollResume)
    function protoMomentumTick(ts: number) {
      if (!protoMomentumActive || !protoTrack) return;
      if (!protoMomentumLastTs) {
        protoMomentumLastTs = ts;
        requestAnimationFrame(protoMomentumTick);
        return;
      }
      const dt = ts - protoMomentumLastTs;
      protoMomentumLastTs = ts;
      protoTrack.scrollLeft += protoMomentumV * dt;
      // wraparound по дублированному контенту, как в protoEnsureHeadroom —
      // но реактивно, т.к. направление инерции известно только по знаку v
      if (protoOriginalWidth > 0) {
        const maxScroll = protoTrack.scrollWidth - protoTrack.clientWidth;
        if (protoTrack.scrollLeft < 0) {
          protoMarkProgrammatic();
          protoTrack.scrollLeft += protoOriginalWidth;
        } else if (protoTrack.scrollLeft > maxScroll) {
          protoMarkProgrammatic();
          protoTrack.scrollLeft -= protoOriginalWidth;
        }
      }
      // декремент масштабирован на dt, чтобы не зависеть от реального фреймрейта
      protoMomentumV *= Math.pow(PROTO_MOMENTUM_DECAY_PER_FRAME, dt / (1000 / 60));
      if (Math.abs(protoMomentumV) < PROTO_MOMENTUM_MIN_V) {
        protoMomentumActive = false;
        return;
      }
      requestAnimationFrame(protoMomentumTick);
    }

    function protoStartMomentum() {
      if (!protoTrack || protoDragSamples.length < 2) return;
      let sumV = 0;
      let count = 0;
      for (let i = 1; i < protoDragSamples.length; i++) {
        const a = protoDragSamples[i - 1];
        const b = protoDragSamples[i];
        const dt = b.t - a.t;
        if (dt <= 0) continue;
        sumV += (b.x - a.x) / dt;
        count++;
      }
      if (count === 0) return;
      const v = sumV / count;
      if (Math.abs(v) < PROTO_MOMENTUM_MIN_V) return;
      protoMomentumV = v;
      protoMomentumActive = true;
      protoMomentumLastTs = 0;
      requestAnimationFrame(protoMomentumTick);
    }

    const protoEndDrag = (e: PointerEvent, allowMomentum: boolean) => {
      if (!protoTrack || !protoDragActive) return;
      protoDragActive = false;
      protoTrack.classList.remove('is-dragging');
      if (protoTrack.hasPointerCapture(e.pointerId)) protoTrack.releasePointerCapture(e.pointerId);
      // pointercancel — жест прерван (например, курсор ушел из окна), инерцию
      // в этом случае не запускаем, только для честного pointerup
      if (allowMomentum) protoStartMomentum();
    };
    protoTrack.addEventListener('pointerup', (e) => protoEndDrag(e as PointerEvent, true));
    protoTrack.addEventListener('pointercancel', (e) => protoEndDrag(e as PointerEvent, false));

    // подавление клика по карточке сразу после драга (порог 6px) — capture-фаза
    // гарантирует остановку раньше bubble-обработчика клика карточки (см. ниже,
    // document.querySelectorAll('.proto-card').forEach(card => card.addEventListener('click', ...))),
    // независимо от порядка регистрации слушателей. Клавиатурный Enter/Space
    // не затронут — там openModal() вызывается напрямую из keydown, не через click.
    protoTrack.addEventListener('click', (e) => {
      if (protoDragDistance > PROTO_DRAG_CLICK_SUPPRESS_PX) {
        e.stopPropagation();
        e.preventDefault();
      }
    }, true);

    window.addEventListener('resize', () => {
      if (protoResizeTimer) clearTimeout(protoResizeTimer);
      protoResizeTimer = setTimeout(protoMeasure, 150);
    });

    protoNavPrev?.addEventListener('click', () => {
      if (!protoTrack) return;
      const distance = protoCardStep() * 3;
      if (distance <= 0) return;
      // пауза СИНХРОННО, до scrollBy — иначе собственный rAF-тикер может
      // выиграть гонку у нативной smooth-анимации и затереть ее тем же кадром
      protoScheduleUserScrollResume();
      protoEnsureHeadroom(-1, distance);
      protoTrack.scrollBy({ left: -distance, behavior: 'smooth' });
    });
    protoNavNext?.addEventListener('click', () => {
      if (!protoTrack) return;
      const distance = protoCardStep() * 3;
      if (distance <= 0) return;
      protoScheduleUserScrollResume();
      protoEnsureHeadroom(1, distance);
      protoTrack.scrollBy({ left: distance, behavior: 'smooth' });
    });

    protoWrap?.addEventListener('pointerenter', () => pauseCarousel('hover'));
    protoWrap?.addEventListener('pointerleave', () => resumeCarousel('hover'));
    protoWrap?.addEventListener('focusin', () => pauseCarousel('focus'));
    protoWrap?.addEventListener('focusout', (e) => {
      if (!protoWrap.contains((e as FocusEvent).relatedTarget as Node | null)) resumeCarousel('focus');
    });
    protoWrap?.addEventListener('pointerdown', () => pauseCarousel('drag'));
    window.addEventListener('pointerup', () => resumeCarousel('drag'));
    window.addEventListener('pointercancel', () => resumeCarousel('drag'));

    document.addEventListener('visibilitychange', () => {
      if (document.hidden) pauseCarousel('tab');
      else resumeCarousel('tab');
    });
    if (document.hidden) pauseCarousel('tab');

    if (protoWrap && 'IntersectionObserver' in window) {
      const protoIo = new IntersectionObserver((entries) => {
        const entry = entries[0];
        if (!entry) return;
        if (entry.isIntersecting) resumeCarousel('viewport');
        else pauseCarousel('viewport');
      }, { threshold: 0.1 });
      protoIo.observe(protoWrap);
    } else {
      resumeCarousel('viewport');
    }
  }

  if (matchMedia('(hover: hover) and (pointer: fine)').matches) {
    const protoCards = Array.from(document.querySelectorAll<HTMLElement>('.proto-card'));
    protoCards.forEach((el, idx) => {
      el.style.transition = 'opacity .6s, transform .25s ease-out';
      const video = el.querySelector('video');
      const prevCard = protoCards[idx - 1];
      const nextCard = protoCards[idx + 1];
      el.addEventListener('pointerenter', () => {
        if (video) { video.style.opacity = '1'; video.play().catch(() => {}); }
        prevCard?.classList.add('spread-left');
        nextCard?.classList.add('spread-right');
      });
      el.addEventListener('pointerleave', () => {
        if (video) { video.style.opacity = '0'; video.pause(); }
        el.style.transform = '';
        prevCard?.classList.remove('spread-left');
        nextCard?.classList.remove('spread-right');
      });
      el.addEventListener('pointermove', (e) => {
        const ev = e as PointerEvent;
        const r = el.getBoundingClientRect();
        const x = (ev.clientX - r.left) / r.width - 0.5;
        const y = (ev.clientY - r.top) / r.height - 0.5;
        el.style.transform = `perspective(600px) rotateY(${x * 6}deg) rotateX(${-y * 6}deg) scale(1.03)`;
      });
    });
  }

  const modal = document.querySelector<HTMLDialogElement>('#proto-modal');
  if (modal) {
    const closeBtn = modal.querySelector<HTMLButtonElement>('.pm-close');
    const titleEl = modal.querySelector<HTMLElement>('.pm-title');
    const badgeEl = modal.querySelector<HTMLElement>('.pm-badge');
    const metaEl = modal.querySelector<HTMLElement>('.pm-meta');
    const linkEl = modal.querySelector<HTMLAnchorElement>('.pm-link');
    const videoEl = modal.querySelector<HTMLVideoElement>('.pm-video');
    const extraClipsEl = modal.querySelector<HTMLElement>('.pm-extra-clips');
    const shotsEl = modal.querySelector<HTMLElement>('.pm-shots');
    const iconEl = modal.querySelector<HTMLImageElement>('.pm-icon');
    const storeLabel = modal.dataset.storeLabel ?? 'View on Google Play';
    let previousOverflow = '';
    let lastCard: HTMLElement | null = null;

    const openModal = (card: HTMLElement) => {
      lastCard = card;
      const id = card.dataset.id ?? '';
      const title = card.dataset.title ?? '';
      const genre = card.dataset.genre ?? '';
      const year = card.dataset.year ?? '';
      const hasClip = card.dataset.clip === '1';
      const hasClipFull = card.dataset.clipFull === '1';
      const shots = Number(card.dataset.shots ?? '0');
      const link = card.dataset.link ?? '';
      const badge = card.dataset.badge ?? '';

      if (titleEl) titleEl.textContent = title;
      if (badgeEl) {
        if (badge) { badgeEl.textContent = badge; badgeEl.style.display = 'inline-flex'; }
        else { badgeEl.style.display = 'none'; }
      }
      if (metaEl) metaEl.textContent = `${genre} · ${year}`;
      if (linkEl) {
        if (link) {
          linkEl.href = link;
          linkEl.textContent = storeLabel;
          linkEl.style.display = 'inline-flex';
        } else {
          linkEl.style.display = 'none';
          linkEl.removeAttribute('href');
        }
      }

      if (videoEl) {
        if (hasClip) {
          videoEl.poster = `/media/prototypes/${id}/poster.jpg`;
          videoEl.src = `/media/prototypes/${id}/${hasClipFull ? 'clip-full.webm' : 'clip.webm'}`;
          videoEl.style.display = 'block';
        } else {
          videoEl.style.display = 'none';
          videoEl.removeAttribute('src');
          videoEl.load();
        }
      }

      if (extraClipsEl) {
        extraClipsEl.innerHTML = '';
        const extraClips = Number(card.dataset.extraClips ?? '0');
        for (let i = 2; i <= 1 + extraClips; i++) {
          const extraVideo = document.createElement('video');
          extraVideo.controls = true;
          extraVideo.muted = true;
          extraVideo.loop = true;
          extraVideo.playsInline = true;
          extraVideo.preload = 'none';
          extraVideo.poster = `/media/prototypes/${id}/poster-${i}.jpg`;
          const source = document.createElement('source');
          source.src = `/media/prototypes/${id}/clip-${i}.webm`;
          source.type = 'video/webm';
          extraVideo.appendChild(source);
          extraClipsEl.appendChild(extraVideo);
        }
      }

      if (shotsEl) {
        shotsEl.innerHTML = '';
        if (shots > 0) {
          for (let i = 1; i <= shots; i++) {
            const img = document.createElement('img');
            img.src = `/media/prototypes/${id}/shots/${i}.webp`;
            img.alt = `${title} — screenshot ${i}`;
            img.loading = 'lazy';
            shotsEl.appendChild(img);
          }
        }
      }

      if (iconEl) {
        if (!hasClip && shots === 0) {
          iconEl.src = `/media/prototypes/${id}/icon.webp`;
          iconEl.alt = title;
          iconEl.style.display = 'block';
        } else {
          iconEl.style.display = 'none';
          iconEl.src = '';
        }
      }

      if (!modal!.open) {
        previousOverflow = document.body.style.overflow;
        document.body.style.overflow = 'hidden';
        modal!.showModal();
        pauseCarousel('modal');
      }
      if (hasClip && videoEl) {
        videoEl.play().catch(() => {});
      }
    };

    document.querySelectorAll<HTMLElement>('.proto-card').forEach((card) => {
      card.addEventListener('click', () => openModal(card));
      card.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          openModal(card);
        }
      });
    });

    closeBtn?.addEventListener('click', () => modal.close());

    modal.addEventListener('click', (e) => {
      if (e.target === modal) modal.close();
    });

    modal.addEventListener('close', () => {
      if (videoEl) {
        videoEl.pause();
        videoEl.removeAttribute('src');
        videoEl.load();
      }
      if (extraClipsEl) extraClipsEl.innerHTML = '';
      document.body.style.overflow = previousOverflow;
      if (lastCard) {
        const v = lastCard.querySelector('video');
        if (v) { v.style.opacity = '0'; v.pause(); }
        lastCard.style.transform = '';
        lastCard = null;
      }
      resumeCarousel('modal');
    });
  }
</script>
